---
interface Props {
  title: string;
  slug: string;
  coverImage: string;
  date?: string;
  location?: string;
  costumeTitles: string[];
  lang: string;
}

const { title, slug, coverImage, date, location, costumeTitles, lang } = Astro.props;

const href = `/${lang === 'en' ? 'en/' : ''}cosplay/events/${slug}`;
---

<a href={href} class="event-card">
  <div class="event-card-image">
    <img src={coverImage} alt={title} loading="lazy" />
  </div>
  <div class="event-card-body">
    <h3 class="event-card-title">{title}</h3>
    <div class="event-card-meta">
      {date && (
        <span class="event-meta-date">{date}</span>
      )}
      {location && (
        <span class="event-meta-location">{location}</span>
      )}
    </div>
    {costumeTitles.length > 0 && (
      <div class="event-costumes">
        {costumeTitles.map((costume) => (
          <span class="event-costume-badge">{costume}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .event-card {
    display: block;
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-left: 8px solid var(--color-accent-alt);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    overflow: hidden;
  }

  .event-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
  }

  .event-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .event-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .event-card-body {
    padding: 1rem 1.25rem;
  }

  .event-card-title {
    font-size: 1.1rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .event-card-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .event-meta-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .event-meta-location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .event-costumes {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .event-costume-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    background: var(--color-accent-alt);
    color: #1a1a1a;
    border: 2px solid var(--color-border);
    box-shadow: 1px 1px 0 var(--color-border);
  }

  @media (max-width: 768px) {
    .event-card {
      box-shadow: 3px 3px 0 var(--color-border);
    }

    .event-card-body {
      padding: 0.75rem 1rem;
    }

    .event-card-title {
      font-size: 1rem;
    }
  }
</style>
