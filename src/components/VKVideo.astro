---
interface Props {
  oid: string | number;
  videoId: string | number;
  hash: string;
  title: string;
  hd?: 2 | 4;
}

const { oid, videoId, hash, title, hd = 2 } = Astro.props;
const src = `https://vk.com/video_ext.php?oid=${oid}&id=${videoId}&hash=${hash}&hd=${hd}`;
---

<iframe
  src={src}
  title={title}
  frameborder="0"
  allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
  allowfullscreen
  loading="lazy"
></iframe>

<style>
  iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
