---
interface Props {
  oid: string | number;
  videoId: string | number;
  title: string;
  lang?: 'ru' | 'en';
}

const { oid, videoId, title, lang = 'ru' } = Astro.props;
const href = `https://vk.com/video${oid}_${videoId}`;
const watchLabel = lang === 'en' ? 'Watch on VK' : 'Смотреть ВКонтакте';
const label = lang === 'en' ? 'VK blocks embedded playback — open in a new tab.' : 'ВКонтакте не разрешает встраивать плеер — открывается в новой вкладке.';
---

<a class="vk-video-card" href={href} target="_blank" rel="noopener" title={title}>
  <div class="vk-video-card__play" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="56" height="56" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
  </div>
  <div class="vk-video-card__body">
    <div class="vk-video-card__badge">VK Video</div>
    <div class="vk-video-card__title">{title}</div>
    <div class="vk-video-card__cta">{watchLabel} →</div>
    <div class="vk-video-card__note">{label}</div>
  </div>
</a>

<style>
  .vk-video-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    aspect-ratio: 16 / 9;
    padding: 1.5rem;
    background: linear-gradient(135deg, #2787f5 0%, #0077ff 100%);
    color: #fff;
    text-decoration: none;
    border: 0;
    box-sizing: border-box;
  }

  .vk-video-card:hover {
    background: linear-gradient(135deg, #0077ff 0%, #005bb5 100%);
  }

  .vk-video-card__play {
    flex: 0 0 auto;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }

  .vk-video-card:hover .vk-video-card__play {
    background: rgba(255, 255, 255, 0.3);
  }

  .vk-video-card__body {
    flex: 1 1 auto;
    min-width: 0;
  }

  .vk-video-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.5rem;
    background: rgba(255, 255, 255, 0.2);
    margin-bottom: 0.5rem;
  }

  .vk-video-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .vk-video-card__cta {
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .vk-video-card__note {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    opacity: 0.75;
    line-height: 1.4;
  }

  @media (max-width: 520px) {
    .vk-video-card {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
      aspect-ratio: auto;
      padding: 1.25rem;
    }
    .vk-video-card__play { width: 64px; height: 64px; }
    .vk-video-card__title { font-size: 1rem; }
  }
</style>
