---
interface Props {
  oid: string | number;
  videoId: string | number;
  hash: string;
  title: string;
  hd?: 2 | 4;
  lang?: 'ru' | 'en';
}

const { oid, videoId, hash, title, hd = 2, lang = 'ru' } = Astro.props;
const src = `https://vk.com/video_ext.php?oid=${oid}&id=${videoId}&hash=${hash}&hd=${hd}`;
const href = `https://vk.com/video${oid}_${videoId}`;
const fallbackLabel = lang === 'en' ? 'Open on VK' : 'Открыть на VK';
---

<div class="vk-video">
  <iframe
    src={src}
    title={title}
    frameborder="0"
    allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
    allowfullscreen
    loading="lazy"
  ></iframe>
  <a class="vk-video__fallback" href={href} target="_blank" rel="noopener">
    {fallbackLabel} →
  </a>
</div>

<style>
  .vk-video {
    position: absolute;
    inset: 0;
  }

  .vk-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .vk-video__fallback {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    background: rgba(39, 135, 245, 0.92);
    color: #fff;
    text-decoration: none;
    border: 0;
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.3);
    z-index: 2;
  }

  .vk-video__fallback:hover {
    background: #0077ff;
  }
</style>
