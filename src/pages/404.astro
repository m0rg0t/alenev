---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Страница не найдена — 404"
  description="Запрошенная страница не найдена. Вернитесь на главную или используйте навигацию."
>
  <section class="not-found">
    <p class="big">404</p>
    <h1>Страница не найдена</h1>
    <p class="lead">
      Похоже, такой страницы здесь нет. Возможно, ссылка устарела или вы ошиблись адресом.
    </p>

    <div class="actions">
      <a href="/" class="btn">На главную</a>
      <a href="/about" class="btn btn-secondary">Об Антоне</a>
    </div>

    <nav class="quicklinks" aria-label="Quick links">
      <h2>Куда дальше?</h2>
      <ul>
        <li><a href="/it">IT-проекты и доклады</a></li>
        <li><a href="/cosplay">Косплей</a></li>
        <li><a href="/audiobooks">Аудиокниги</a></li>
        <li><a href="/podcasts">Подкаст «Косплей и прочие штуки»</a></li>
        <li><a href="/publications">Публикации</a></li>
      </ul>
    </nav>
  </section>

  <style>
    .not-found {
      max-width: 700px;
      margin: 0 auto;
      text-align: center;
      padding: 2rem 1rem;
    }

    .big {
      font-size: clamp(6rem, 18vw, 11rem);
      font-weight: 700;
      line-height: 1;
      color: var(--color-primary);
      margin: 0 0 1rem;
      letter-spacing: -0.05em;
    }

    h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      margin-bottom: 1.5rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.5rem 1.25rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .lead {
      font-size: 1.1rem;
      color: var(--color-text-muted);
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }

    .actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }

    .quicklinks {
      text-align: left;
      background: var(--color-surface);
      padding: 1.5rem 2rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-accent-alt);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .quicklinks h2 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--color-text);
    }

    .quicklinks ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .quicklinks li {
      padding: 0.4rem 0;
      border-bottom: 1px dashed var(--color-text-muted);
    }

    .quicklinks li:last-child {
      border-bottom: none;
    }

    .quicklinks a {
      color: var(--color-text);
      text-decoration: none;
      font-weight: 500;
    }

    .quicklinks a:hover {
      color: var(--color-primary);
      text-decoration: underline;
    }
  </style>
</BaseLayout>
