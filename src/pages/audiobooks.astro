---
import BaseLayout from '../layouts/BaseLayout.astro';

const audiobooks = [
  {
    title: "Адские секретарши и властный босс",
    author: "Татьяна Охитина",
    cover: "adskie-sekretarshi.jpg",
    url: "https://www.litres.ru/audiobook/tatyana-ohitina-31323612/adskie-sekretarshi-i-vlastnyy-boss-71470699/"
  },
  {
    title: "И пришёл Хрюка…",
    author: "Ник Винсент",
    cover: "i-prishel-hruka.jpg",
    url: "https://www.litres.ru/audiobook/nik-vinsent-33147955/i-prishel-hruka-71420611/"
  },
  {
    title: "Бумажный дом",
    author: "Такаши Итияма",
    cover: "bumazhniy-dom.jpg",
    url: "https://www.litres.ru/audiobook/takashi-itiyama/bumazhnyy-dom-70874453/"
  },
  {
    title: "Сумеречный охотник 2",
    author: "Илья Соломенный",
    cover: "sumerechniy-ohotnik-2.jpg",
    url: "https://www.litres.ru/audiobook/ilya-solomennyy/sumerechnyy-ohotnik-2-70459078/"
  },
  {
    title: "Илья Муромец и Калин-царь",
    author: "Народное творчество",
    cover: "ilya-muromec.jpg",
    url: "https://www.litres.ru/audiobook/eposy-legendy-i-skazaniya/ilya-muromec-i-kalin-car-70489246/"
  },
  {
    title: "Сумеречный охотник",
    author: "Илья Соломенный",
    cover: "sumerechniy-ohotnik.jpg",
    url: "https://www.litres.ru/audiobook/ilya-solomennyy/sumerechnyy-ohotnik-70246126/"
  },
  {
    title: "Загадать желание",
    author: "Катя Ли",
    cover: "zagadat-zhelanie.jpg",
    url: "https://www.litres.ru/audiobook/katya-li-32368102/zagadat-zhelanie-69829357/"
  },
  {
    title: "Семен Подъячев",
    author: "Максим Горький",
    cover: "semen-podyachev.jpg",
    url: "https://www.litres.ru/audiobook/maksim-gorkiy/semen-podyachev-69842725/"
  },
  {
    title: "О наших достижениях",
    author: "Максим Горький",
    cover: "o-nashih-dostizheniyah.jpg",
    url: "https://www.litres.ru/audiobook/maksim-gorkiy/o-nashih-dostizheniyah-69647014/"
  },
  {
    title: "Интроверт",
    author: "Джон Смит",
    cover: "introvert.jpg",
    url: "https://www.litres.ru/audiobook/dzhon-smit-32488950/introvert-kak-introvertam-obresti-vnutrennuu-silu-zavo-69541339/"
  },
  {
    title: "Сага о бессмертных духах. Книга 0",
    author: "Виталий Кириллов",
    cover: "saga-o-bessmertnyh-duhah.jpg",
    url: "https://www.litres.ru/audiobook/vitaliy-aleksandrovi/saga-o-bessmertnyh-duhah-kniga-0-predystoriya-ordena-69546844/"
  },
  {
    title: "Первая прогулка богдыхана",
    author: "Влас Дорошевич",
    cover: "pervaya-progulka-bogdyhana.jpg",
    url: "https://www.litres.ru/audiobook/vlas-doroshevich/pervaya-progulka-bogdyhana-69549196/"
  }
];
---

<BaseLayout
  title="Аудиокниги - Антон Ленев"
  description="Аудиокниги в озвучке Антона Ленева. Более 12 произведений на платформе Litres: художественная литература, классика, фэнтези и нон-фикшн."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://alenev.ru/" },
      { "@type": "ListItem", "position": 2, "name": "Audiobooks", "item": "https://alenev.ru/audiobooks/" }
    ]
  })} />
  <h1>🎧 Аудиокниги</h1>

  <section class="intro">
    <p class="lead">
      Антон Ленев — чтец аудиокниг на платформе Litres. В каталоге — современная художественная
      литература, фэнтези и классика, включая рассказы Максима Горького («Семён Подъячев»,
      «О наших достижениях») и произведения серии «Сумеречный охотник» Ильи Соломенного.
      <a href="/about">Подробнее об Антоне →</a>
    </p>
  </section>

  <section class="platform">
    <div class="platform-card">
      <h2>Litres</h2>
      <p>
        Здесь вы можете найти все аудиокниги, озвученные мной.
        Каждая книга — это результат тщательной работы над интонацией, темпом и передачей атмосферы произведения.
      </p>
      <a href="https://www.litres.ru/author/anton-lenev/" target="_blank" rel="noopener" class="btn-primary">
        Слушать на Litres
      </a>
    </div>
  </section>

  <section class="books">
    <h2>Мои аудиокниги</h2>
    <div class="books-grid">
      {audiobooks.map((book) => (
        <article class="book-card">
          <a href={book.url} target="_blank" rel="noopener">
            <img src={`/audiobooks/${book.cover}`} alt={book.title} />
            <div class="book-info">
              <h3>{book.title}</h3>
              <p class="author">{book.author}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <style>
    /* Page Title */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .intro {
      margin-bottom: 3rem;
    }

    .lead {
      font-size: 1.2rem;
      line-height: 1.8;
      color: var(--color-text);
      background: var(--color-surface);
      padding: 2rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .platform {
      margin-bottom: 3rem;
    }

    /* Books Section */
    .books {
      margin-bottom: 4rem;
    }

    .books h2 {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      text-align: center;
      display: block;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
      background: var(--color-accent-alt);
      color: var(--color-text);
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    :global([data-theme="dark"]) .books h2 {
      color: #1a1a1a;
    }

    .books-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1.5rem;
    }

    .book-card {
      background: var(--color-surface);
      overflow: hidden;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .book-card:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
    }

    .book-card a {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .book-card img {
      width: 100%;
      aspect-ratio: 2/3;
      object-fit: cover;
      display: block;
      border-bottom: var(--border-width) solid var(--color-border);
    }

    .book-info {
      padding: 1rem;
    }

    .book-info h3 {
      font-size: 0.95rem;
      line-height: 1.4;
      margin-bottom: 0.5rem;
      color: var(--color-text);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-transform: uppercase;
    }

    .book-info .author {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin: 0;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      .books-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .book-card {
        box-shadow: 3px 3px 0 var(--color-border);
      }

      .book-info h3 {
        font-size: 0.85rem;
      }

      .book-info .author {
        font-size: 0.75rem;
      }
    }

    .platform-card {
      background: var(--color-accent);
      padding: 2.5rem;
      border: var(--border-width) solid var(--color-border);
      text-align: center;
      box-shadow: 6px 6px 0 var(--color-border);
    }

    .platform-card h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: var(--color-text);
      text-transform: uppercase;
    }

    :global([data-theme="dark"]) .platform-card h2,
    :global([data-theme="dark"]) .platform-card p {
      color: #1a1a1a;
    }

    /* Dark mode: better button contrast on yellow */
    :global([data-theme="dark"]) .platform-card .btn-primary {
      background: #1a1a1a;
      color: var(--color-accent);
      border-color: #1a1a1a;
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
    }

    :global([data-theme="dark"]) .platform-card .btn-primary:hover {
      background: #333333;
      box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.3);
    }

    .platform-card p {
      color: var(--color-text);
      line-height: 1.8;
      margin-bottom: 2rem;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
      text-transform: none;
    }

    .btn-primary {
      display: inline-block;
      padding: 1rem 2rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 4px 4px 0 var(--color-border);
    }

    .btn-primary:hover {
      transform: translate(-2px, -2px);
      box-shadow: 6px 6px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    @media (max-width: 768px) {
      .platform-card {
        padding: 1.5rem;
        box-shadow: 4px 4px 0 var(--color-border);
      }

      .btn-primary {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }
    }
  </style>
</BaseLayout>
