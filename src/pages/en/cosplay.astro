---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CostumeCard from '../../components/CostumeCard.astro';
import EventCard from '../../components/EventCard.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('en');

const costumes = (await getCollection('costumes'))
  .filter(entry => entry.data.lang === 'en')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const events = (await getCollection('cosplay-events'))
  .filter(entry => entry.data.lang === 'en')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const allCostumes = (await getCollection('costumes'))
  .filter(entry => entry.data.lang === 'en');

function getCostumeTitles(costumeSlugs: string[]): string[] {
  return costumeSlugs.map(slug => {
    const found = allCostumes.find(c => c.data.costumeId === slug);
    return found?.data.title ?? slug;
  });
}
---

<BaseLayout
  title="Cosplay - Anton Lenev"
  description="Cosplay portfolio by Anton Lenev: costumes from Dead Space, Mass Effect, Skyrim, Predator and more. Build logs, materials, photo shoots, and event coverage."
>
  <h1>{t('cosplay.title')}</h1>

  <section class="intro">
    <p class="lead">
      Cosplay portfolio by Anton Lenev — costumes inspired by Dead Space, Mass Effect, Skyrim,
      Overwatch, Predator and Russian folklore. Builds combine EVA foam, 3D printing,
      electronics and lighting. The Isaac Clarke (Dead Space) costume is one of the most
      technically complex projects and has been featured on Habr, DTF and Instructables.
      <a href="/en/about">More about Anton →</a>
    </p>
  </section>

  <section class="costumes-section">
    <h2>{t('cosplay.costumes')}</h2>
    <div class="costumes-grid">
      {costumes.map(costume => (
        <CostumeCard
          title={costume.data.title}
          slug={costume.data.costumeId}
          coverImage={costume.data.coverImage}
          character={costume.data.character}
          franchise={costume.data.franchise}
          lang="en"
        />
      ))}
    </div>
  </section>

  {events.length > 0 && (
    <section class="events-section">
      <h2>{t('cosplay.events')}</h2>
      <div class="events-grid">
        {events.map(event => (
          <EventCard
            title={event.data.title}
            slug={event.data.costumeId}
            coverImage={event.data.coverImage}
            date={event.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            location={event.data.location}
            costumeTitles={getCostumeTitles(event.data.costumes)}
            lang="en"
          />
        ))}
      </div>
    </section>
  )}

  <section class="awards-section">
    <h2>Awards</h2>

    <article class="video-article">
      <h3>🏆 "Walk Towards the Sun 2018" festival — Grand Prix (Samara)</h3>
      <p>
        Anton Lenev's Overwatch project (character: McCree) took the <strong>Grand Prix</strong> at the
        "Walk Towards the Sun 2018" cosplay festival in Samara — awarded by the festival's sponsor
        <em>"Game &amp; Reality"</em>. Photos: Slava Grebyonkin (Rybinsk / Moscow).
      </p>
      <div class="links">
        <a href="https://vk.com/wall-21253509_21745" target="_blank" rel="noopener">VK post</a>
      </div>
    </article>

    <article class="video-article">
      <h3>🏆 "Ohtacon 2020" — "Best Cosplay" nomination (St. Petersburg)</h3>
      <p>
        At the "Ohtacon" cosplay contest final held at the Okhta Mall in St. Petersburg on March 7, 2020,
        Anton Lenev won the <strong>"Best Cosplay"</strong> category as Thor from <em>Thor: Ragnarok</em>.
        The contest featured 28 participants from cities across Russia, with 12 advancing to the final.
        Coverage: Tribuna.ee, photographer Arseniy Denisov.
      </p>
      <div class="links">
        <a href="https://tribuna.ee/attributes/kosplay/" target="_blank" rel="noopener">Tribuna.ee</a>
        <a href="/archive/tribuna-ohtakon-2020">Archive</a>
      </div>
    </article>
  </section>

  <section class="videos-section">
    <h2>Videos & streams</h2>

    <article class="video-article">
      <h3>Evening stream: cosplay with Anton Lenev (Rybinsk, 2019)</h3>
      <p>
        Local Rybinsk evening stream "17:40" featuring Anton as a guest — a conversation about cosplay: costumes, materials, events and the path into the community.
      </p>
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/E6M5PwOPUUI"
          title="Cosplay / guest Anton Lenev / Evening stream 17:40"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="/archive/cosplay-stream-2019">Text version →</a>
        <a href="https://www.youtube.com/watch?v=E6M5PwOPUUI" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="video-article">
      <h3>Overwatch Cosplayers Assemble — community tribute on the game's anniversary</h3>
      <p>
        A community "roll-call" of Overwatch heroes produced as a collective gift for the game's anniversary — 19 cosplayers in character.
        Anton Lenev appears as one of three McCrees in the video. Other heroes on screen include
        Mei, D.Va (×2), Mercy (×2), Junkrat, Torbjörn, Brigitte, Soldier: 76 (×2), Reaper, Widowmaker, Ana,
        McCree (Konstantin Logvinov, Igor Krivonogov), Ashe, Genji and Zarya.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=220916317&id=456240978&hash=342872c403b95e08&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="Overwatch Cosplayers Assemble"
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="https://vk.com/wall-79997904_596356" target="_blank" rel="noopener">VK post</a>
        <a href="https://vk.com/video220916317_456240978" target="_blank" rel="noopener">Video on VK</a>
      </div>
    </article>

    <article class="video-article">
      <h3>ASIAVOL — jury defile: McCree (Overwatch)</h3>
      <p>
        Anton Lenev's jury defile at the ASIAVOL festival as McCree from Overwatch.
      </p>
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/oc0lnoCJdpQ"
          title="ASIAVOL | Jury defile — Anton Lenev (McCree / Overwatch)"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=oc0lnoCJdpQ" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>
  </section>

  <style>
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 { color: #1a1a1a; }

    .intro { margin-bottom: 3rem; }

    .lead {
      font-size: 1.2rem;
      line-height: 1.8;
      color: var(--color-text);
      background: var(--color-surface);
      padding: 2rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .lead a {
      color: var(--color-primary-dark);
      text-decoration: underline;
      font-weight: 700;
    }

    .lead a:hover { color: var(--color-secondary); }

    :global([data-theme="dark"]) .lead a { color: var(--color-accent); }

    .costumes-section, .events-section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    .events-section h2 { background: var(--color-accent-alt); color: var(--color-text); }
    :global([data-theme="dark"]) .events-section h2 { color: #1a1a1a; }

    .costumes-grid, .events-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .videos-section,
    .awards-section { margin-bottom: 4rem; }

    .awards-section h2 {
      background: var(--color-accent-alt);
      color: var(--color-text);
    }

    :global([data-theme="dark"]) .awards-section h2 { color: #1a1a1a; }

    .videos-section h2 {
      background: var(--color-accent);
      color: var(--color-text);
    }

    :global([data-theme="dark"]) .videos-section h2 { color: #1a1a1a; }

    .video-article {
      background: var(--color-surface);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin-bottom: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .video-article h3 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      color: var(--color-text);
    }

    .video-article p {
      color: var(--color-text-muted);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .video-embed {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      margin: 1rem 0;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 4px 4px 0 var(--color-border);
      background: #000;
    }

    .video-embed iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .video-article .links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .video-article .links a {
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .video-article .links a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    @media (max-width: 768px) {
      h1 { font-size: 1.75rem; }
      .costumes-grid, .events-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
