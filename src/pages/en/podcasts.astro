---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Podcasts — Anton Lenev"
  description="Cosplay and Other Things — a podcast by Anton Lenev about cosplay, pop culture and creativity. Available on Spotify, Apple Podcasts and more."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://alenev.ru/en/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Podcasts', 'item': 'https://alenev.ru/en/podcasts/' }
    ]
  })} />
  <h1>🎙️ Podcasts</h1>

  <p class="page-intro">
    "Cosplay and Other Things" is hosted by Anton Lenev — a programmer and cosplayer from Rybinsk, Russia.
    <a href="/en/about">More about Anton →</a>
  </p>

  <section class="podcast-main">
    <div class="podcast-card featured">
      <h2>Cosplay and Other Things</h2>
      <p class="description">
        A podcast about cosplay, pop culture, creativity and everything related.
        We discuss costume creation, event participation, interesting projects and share experiences.
      </p>
      <div class="podcast-links">
        <a href="https://cosplay.mave.digital/" target="_blank" rel="noopener" class="btn-primary">
          Mave
        </a>
        <a href="https://open.spotify.com/show/73jsU2vpqrcqpFkRQzU3j2" target="_blank" rel="noopener" class="btn-platform spotify">
          Spotify
        </a>
        <a href="https://podcasts.apple.com/ru/podcast/косплей-и-прочие-штуки/id1520630151" target="_blank" rel="noopener" class="btn-platform apple">
          Apple Podcasts
        </a>
        <a href="https://music.yandex.ru/album/11222632" target="_blank" rel="noopener" class="btn-platform yandex">
          Yandex Music
        </a>
      </div>
    </div>
  </section>

  <section class="guest-section">
    <h2 class="guest-heading">Guest appearances</h2>

    <article class="guest-card">
      <h3>"Ne Bez Dela" #65 — A costume made from a yoga mat</h3>
      <p class="meta">Guest episode · October 28, 2020 · 18 min · Russian</p>
      <p class="description">
        A conversation about cosplay: the path into the community, why "jack of all trades" is the base requirement for a cosplayer, crafting costumes out of unusual materials (yes, including yoga mats), festival life, and what keeps people spending a full year on a single costume.
      </p>
      <audio controls preload="none" class="audio-player">
        <source src="https://api.mave.digital/storage/podcasts/b23fba55-ca34-407b-9f32-09856f0fe8c8/episodes/15b2dbb1-2f6b-47a6-be8d-c4d5695c3526.mp3" type="audio/mpeg" />
        Your browser does not support the audio element.
      </audio>
      <div class="guest-links">
        <a href="https://nebezdela.mave.digital/ep-65" target="_blank" rel="noopener" class="btn-primary">Open on Mave</a>
        <a href="https://vk.com/nebezdela" target="_blank" rel="noopener" class="btn-secondary">"Ne Bez Dela" show</a>
      </div>
    </article>
  </section>

  <style>
    /* Page Title */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .podcast-main {
      margin-bottom: 3rem;
    }

    /* Featured Podcast Card */
    .podcast-card {
      background: var(--color-surface);
      padding: 2.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 6px 6px 0 var(--color-border);
      text-align: center;
    }

    .podcast-card.featured {
      background: var(--color-accent);
      border-left: 8px solid var(--color-primary);
    }

    .podcast-card h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: var(--color-text);
      text-transform: uppercase;
    }

    :global([data-theme="dark"]) .podcast-card.featured h2,
    :global([data-theme="dark"]) .podcast-card.featured .description {
      color: #1a1a1a;
    }

    /* Dark mode: better button contrast on yellow */
    :global([data-theme="dark"]) .podcast-card.featured .btn-primary {
      background: #1a1a1a;
      color: var(--color-accent);
      border-color: #1a1a1a;
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
    }

    :global([data-theme="dark"]) .podcast-card.featured .btn-primary:hover {
      background: #333333;
      box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.3);
    }

    .description {
      color: var(--color-text);
      line-height: 1.8;
      font-size: 1.1rem;
      margin-bottom: 1.5rem;
      text-transform: none;
    }

    .podcast-links {
      margin-top: 2rem;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }

    .btn-primary, .btn-platform {
      display: inline-block;
      padding: 1rem 2rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 4px 4px 0 var(--color-border);
    }

    .btn-primary:hover, .btn-platform:hover {
      transform: translate(-2px, -2px);
      box-shadow: 6px 6px 0 var(--color-border);
    }

    .btn-primary:hover {
      background: var(--color-primary-dark);
    }

    .btn-platform.spotify {
      background: #1DB954;
    }

    .btn-platform.spotify:hover {
      background: #1aa34a;
    }

    .btn-platform.apple {
      background: #FC3C44;
    }

    .btn-platform.apple:hover {
      background: #e0353c;
    }

    .btn-platform.yandex {
      background: #FFCC00;
      color: #1a1a1a;
    }

    .btn-platform.yandex:hover {
      background: #e6b800;
    }

    .section {
      margin-top: 3rem;
    }

    .guest-section {
      margin-top: 3rem;
    }

    .guest-heading {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      display: inline-block;
      background: var(--color-accent-alt);
      color: var(--color-text);
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    :global([data-theme="dark"]) .guest-heading { color: #1a1a1a; }

    .guest-card {
      background: var(--color-surface);
      padding: 1.75rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: 4px 4px 0 var(--color-border);
      margin-bottom: 1.5rem;
    }

    .guest-card h3 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      color: var(--color-text);
    }

    .guest-card .meta {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin-bottom: 1rem;
    }

    .guest-card .description {
      color: var(--color-text);
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .audio-player {
      width: 100%;
      margin: 0.5rem 0 1rem;
    }

    .guest-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .guest-card .btn-primary,
    .guest-card .btn-secondary {
      padding: 0.65rem 1.25rem;
      font-size: 0.9rem;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      font-weight: 700;
      text-transform: uppercase;
    }

    .guest-card .btn-primary {
      background: var(--color-primary);
      color: white;
    }

    .guest-card .btn-secondary {
      background: var(--color-surface);
      color: var(--color-text);
    }

    .guest-card .btn-primary:hover,
    .guest-card .btn-secondary:hover {
      transform: translate(-2px, -2px);
      box-shadow: 5px 5px 0 var(--color-border);
    }

    .section h2 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      display: inline-block;
      background: var(--color-accent-alt);
      color: var(--color-text);
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    :global([data-theme="dark"]) .section h2 {
      color: #1a1a1a;
    }

    .section p {
      color: var(--color-text-muted);
      line-height: 1.6;
      text-transform: none;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      .podcast-card {
        padding: 1.5rem;
        box-shadow: 4px 4px 0 var(--color-border);
      }

      .btn-primary, .btn-platform {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 1.5rem;
      }

      .podcast-links {
        gap: 0.75rem;
      }
    }
  </style>
</BaseLayout>
