---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all archives to check which publications have archived versions
const archives = await getCollection('archives');
const archivesByUrl = new Map(archives.map(a => [a.data.originalUrl, a.slug]));
---

<BaseLayout
  title="Publications — Anton Lenev"
  description="Articles and publications by Anton Lenev on Habr, Instructables and other platforms. Topics: cosplay, electronics, AI, programming."
>
  <h1>📝 Publications & Articles</h1>

  <p class="page-intro">
    A selection of bylined articles and media mentions of Anton Lenev — on Habr, Tproger,
    Instructables, Igromania, Kanobu, DTF and Russian regional press.
    <a href="/en/about">About the author →</a>
  </p>

  <section class="section">
    <h2>My Articles</h2>

    <article class="publication">
      <h3>OwlEye Necklace - Jewelry That Helps Visually Impaired People Navigate</h3>
      <p>Detailed description of the OwlEye project on Instructables</p>
      <div class="links">
        <a href="https://www.instructables.com/OwlEye-Necklace-Jewelry-That-Helps-Visually-Impair/" target="_blank" rel="noopener">Original</a>
        {archivesByUrl.has("https://www.instructables.com/OwlEye-Necklace-Jewelry-That-Helps-Visually-Impair/") && (
          <a href={`/archive/${archivesByUrl.get("https://www.instructables.com/OwlEye-Necklace-Jewelry-That-Helps-Visually-Impair/")}`} class="archive-link">Archive</a>
        )}
      </div>
    </article>

    <article class="publication">
      <h3>OwlEye Necklace — Helping the Visually Impaired</h3>
      <p>Article about the OwlEye project on Habr</p>
