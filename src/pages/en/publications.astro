        <a href="https://habr.com/ru/articles/482280/" target="_blank" rel="noopener">Original</a>
        {archivesByUrl.has("https://habr.com/ru/articles/482280/") && (
          <a href={`/archive/${archivesByUrl.get("https://habr.com/ru/articles/482280/")}`} class="archive-link">Archive</a>
