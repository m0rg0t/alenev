---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CosplayMeta from '../../../../components/CosplayMeta.astro';
import CosplayGallery from '../../../../components/CosplayGallery.astro';
import Lightbox from '../../../../components/Lightbox.astro';
import { useTranslations } from '../../../../i18n';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const t = useTranslations('en');

export async function getStaticPaths() {
  const shoots = (await getCollection('cosplay'))
    .filter(e => e.data.lang === 'en');
  return shoots.map(entry => ({
    params: {
      costume: entry.data.costume,
      slug: entry.slug.replace(/en$/, ''),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

let manifest = { images: [], video: null } as { images: Array<{ webp: string; thumb: string; width: number; height: number }>; video: string | null };
try {
  const manifestPath = join(process.cwd(), 'public', 'cosplay', entry.data.folder, 'manifest.json');
  manifest = JSON.parse(readFileSync(manifestPath, 'utf-8'));
} catch (e) {
  console.warn(`Could not read manifest for ${entry.data.folder}:`, e);
}

const costumes = (await getCollection('costumes'))
  .filter(c => c.data.lang === 'en' && c.data.costumeId === entry.data.costume);
const costume = costumes[0];
---

<BaseLayout title={`${entry.data.title} - Cosplay`}>
  <h1>{entry.data.title}</h1>

  <CosplayMeta
    photographer={entry.data.photographer}
    photographerUrl={entry.data.photographerUrl}
    location={entry.data.location}
    date={entry.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    event={entry.data.event}
    tags={entry.data.tags}
    lang="en"
  />

  <section class="description"><Content /></section>

  {entry.data.videos && entry.data.videos.length > 0 && (
    <section class="video-section">
      <h2>{t('cosplay.video')}</h2>
      {entry.data.videos.map(video => (
        <div class="video-wrapper">
          <video controls preload="metadata" class="video-player">
            <source src={video.url} type="video/mp4" />
          </video>
          {video.title && <p class="video-title">{video.title}</p>}
        </div>
      ))}
    </section>
  )}

  {manifest.images.length > 0 && (
    <section class="gallery-section">
      <h2>{t('cosplay.photos')} ({manifest.images.length})</h2>
      <CosplayGallery images={manifest.images} folder={entry.data.folder} />
      <Lightbox />
    </section>
  )}

  <div class="back-link-wrapper">
    <a href={`/en/cosplay/${entry.data.costume}`} class="back-link">
      &larr; {t('cosplay.backToCostume')}{costume ? `: ${costume.data.title}` : ''}
    </a>
  </div>

  <style>
    h1 { font-size: 2.5rem; margin-bottom: 1rem; color: var(--color-text); text-transform: uppercase; display: inline-block; background: var(--color-accent); padding: 0.75rem 1.5rem; border: var(--border-width) solid var(--color-border); box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border); }
    :global([data-theme="dark"]) h1 { color: #1a1a1a; }
    .description { margin: 2rem 0; background: var(--color-surface); padding: 2rem; border: var(--border-width) solid var(--color-border); border-left: 8px solid var(--color-primary); box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border); line-height: 1.8; color: var(--color-text); }
    .description :global(p) { margin-bottom: 1rem; }
    .description :global(p:last-child) { margin-bottom: 0; }
    .video-section { margin-bottom: 3rem; }
    .video-wrapper { margin-bottom: 1.5rem; }
    .video-player { width: 100%; max-width: 800px; border: var(--border-width) solid var(--color-border); box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border); }
    .video-title { margin-top: 0.5rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; font-size: 0.85rem; }
    .gallery-section { margin-bottom: 3rem; }
    h2 { font-size: 1.5rem; margin-bottom: 2rem; display: inline-block; background: var(--color-primary); color: white; padding: 0.5rem 1rem; border: var(--border-width) solid var(--color-border); box-shadow: 3px 3px 0 var(--color-border); text-transform: uppercase; }
    .back-link-wrapper { margin-top: 2rem; }
    .back-link { display: inline-block; padding: 0.75rem 1.5rem; background: var(--color-surface); color: var(--color-text); text-decoration: none; font-weight: 700; text-transform: uppercase; font-size: 0.875rem; border: var(--border-width) solid var(--color-border); box-shadow: 3px 3px 0 var(--color-border); }
    .back-link:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--color-border); background: var(--color-accent); color: #1a1a1a; }
    @media (max-width: 768px) { h1 { font-size: 1.75rem; } }
  </style>
</BaseLayout>
