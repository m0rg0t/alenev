---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('en');
---

<BaseLayout
  title="Anton Lenev — Developer, Cosplayer, Podcaster"
  description="Anton Lenev — programmer, cosplayer, audiobook narrator and podcast host from Rybinsk, Russia. IT articles, podcasts, cosplay and publications."
>
  <section class="hero">
    <h1>Anton Lenev</h1>
    <p class="subtitle">{t('about.description')}</p>

    <p class="bio">
      Anton Lenev is a programmer from Rybinsk, Russia, working as CTO and Frontend Developer at Viewst Inc.
      He hosts the <strong>«Cosplay and Other Things»</strong> podcast — episodes are available on Spotify, Apple Podcasts and Yandex Music.
      As an audiobook narrator he has voiced over 12 titles on <a href="https://www.litres.ru/author/anton-lenev/" target="_blank" rel="noopener">Litres</a>.
      He builds cosplay costumes inspired by games and films: Dead Space, Mass Effect, Skyrim, Predator, Overwatch.
      His work has been featured on Habr, Tproger, Instructables, and in Russian regional media.
      <a href="/en/about" class="bio-more">More about Anton →</a>
    </p>

    <div class="about-images">
      <picture>
        <source type="image/webp" srcset="/images/anton-lenev-300.webp 1x, /images/anton-lenev-600.webp 2x" />
        <img src="/images/anton-lenev.jpg" alt="Anton Lenev" width="853" height="1280" fetchpriority="high" style="max-width:300px;width:100%;height:auto;" />
      </picture>
      <picture>
        <source type="image/webp" srcset="/images/anton-lenev-art-300.webp 1x, /images/anton-lenev-art-600.webp 2x" />
        <img src="/images/anton-lenev-art.jpg" alt="Anton Lenev Art" width="1280" height="1280" loading="lazy" style="max-width:300px;width:100%;height:auto;" />
      </picture>
    </div>
  </section>

  <section class="categories">
    <h2>Categories</h2>
    <div class="grid">
      <a href="/en/it" class="card">
        <h3>💻 IT</h3>
        <p>Projects, talks and articles about development</p>
      </a>

      <a href="/en/podcasts" class="card">
        <h3>🎙️ Podcasts</h3>
        <p>"Cosplay and Other Things" podcast</p>
      </a>

      <a href="/en/audiobooks" class="card">
        <h3>🎧 Audiobooks</h3>
        <p>Narration on Litres platform</p>
      </a>

      <a href="/en/cosplay" class="card">
        <h3>🎭 Cosplay</h3>
        <p>Photos and videos of costumes</p>
      </a>

      <a href="/en/publications" class="card">
        <h3>📝 Publications</h3>
        <p>Articles and media mentions</p>
      </a>

      <a href="/en/other" class="card">
        <h3>🎯 Other</h3>
        <p>VK Mini apps, Yandex skills and other projects</p>
      </a>
    </div>
  </section>

  <section class="social">
    <h2>{t('social.title')}</h2>
    <div class="social-links">
      <a href="https://t.me/AntonLenev" target="_blank" rel="noopener" data-brand="telegram">Telegram</a>
      <a href="https://github.com/m0rg0t/" target="_blank" rel="noopener" data-brand="github">GitHub</a>
      <a href="https://vk.com/m0rg0t" target="_blank" rel="noopener" data-brand="vk">VK</a>
      <a href="https://instagram.com/antonlenev" target="_blank" rel="noopener" data-brand="instagram">Instagram</a>
      <a href="https://twitter.com/m0rg0t" target="_blank" rel="noopener" data-brand="twitter">Twitter</a>
      <a href="https://www.linkedin.com/in/anton-lenev-98414530/" target="_blank" rel="noopener" data-brand="linkedin">LinkedIn</a>
    </div>
  </section>

  <style>
    /* ===== HERO SECTION ===== */
    .hero {
      text-align: center;
      padding: 3rem 2rem;
      background: var(--color-accent);
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 3.5rem;
      margin-bottom: 1rem;
      color: var(--color-text);
      text-transform: uppercase;
      letter-spacing: -0.03em;
    }

    :global([data-theme="dark"]) .hero h1 {
      color: #1a1a1a;
    }

    .subtitle {
      font-size: 1.25rem;
      color: var(--color-text);
      margin-bottom: 2rem;
      font-weight: 500;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    :global([data-theme="dark"]) .subtitle {
      color: #1a1a1a;
    }

    .bio {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--color-text);
      max-width: 700px;
      margin: 0 auto 2rem;
      text-align: left;
      background: var(--color-surface);
      border: var(--border-width) solid var(--color-border);
      padding: 1.25rem 1.5rem;
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .bio strong { font-weight: 700; }

    .bio a {
      color: var(--color-primary-dark);
      text-decoration: underline;
      font-weight: 700;
    }

    .bio a:hover { color: var(--color-secondary); }

    .bio-more {
      display: inline-block;
      margin-top: 0.5rem;
    }

    .about-images {
      display: flex;
      gap: 2rem;
      justify-content: center;
      align-items: flex-start;
      flex-wrap: wrap;
      margin-top: 2rem;
    }

    .about-images img {
      max-width: 300px;
      width: 100%;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .about-images img:hover {
      transform: translate(-4px, -4px) rotate(-1deg);
      box-shadow: 8px 8px 0 var(--color-border);
    }

    .about-images img:nth-child(even):hover {
      transform: translate(-4px, -4px) rotate(1deg);
    }

    /* ===== CATEGORIES SECTION ===== */
    .categories {
      margin-top: 4rem;
    }

    .categories h2 {
      font-size: 1.75rem;
      margin-bottom: 2rem;
      text-align: center;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
    }

    .categories > h2 {
      display: block;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
    }

    /* Grid for cards */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    /* Card styling */
    .card {
      background: var(--color-surface);
      padding: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      text-decoration: none;
      color: var(--color-text);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
      display: block;
    }

    .card:hover {
      transform: translate(-2px, -2px);
      box-shadow: 6px 6px 0 var(--color-border);
    }

    /* Card colors for variety */
    .card:nth-child(1) { border-left: 6px solid var(--color-primary); }
    .card:nth-child(2) { border-left: 6px solid var(--color-accent); }
    .card:nth-child(3) { border-left: 6px solid var(--color-accent-alt); }
    .card:nth-child(4) { border-left: 6px solid var(--color-secondary); }
    .card:nth-child(5) { border-left: 6px solid var(--color-primary); }
    .card:nth-child(6) { border-left: 6px solid var(--color-accent); }

    :global([data-theme="dark"]) .card:nth-child(2),
    :global([data-theme="dark"]) .card:nth-child(6) {
      border-left-color: var(--color-accent);
    }

    .card h3 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
    }

    .card p {
      color: var(--color-text-muted);
      font-size: 0.95rem;
      text-transform: none;
    }

    /* ===== SOCIAL SECTION ===== */
    .social {
      margin-top: 4rem;
    }

    .social h2 {
      font-size: 1.75rem;
      margin-bottom: 2rem;
      text-align: center;
      display: block;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
      background: var(--color-accent-alt);
      color: var(--color-text);
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
    }

    :global([data-theme="dark"]) .social h2 {
      color: #1a1a1a;
    }

    .social-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .social-links a {
      padding: 0.75rem 1.5rem;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.875rem;
      box-shadow: 3px 3px 0 var(--color-border);
      transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .social-links a:hover {
      transform: translate(-2px, -2px);
      box-shadow: 5px 5px 0 var(--color-border);
    }

    /* Brand-specific colors */
    .social-links a[data-brand="telegram"] {
      background: #FF6B35;
      color: white;
    }
    .social-links a[data-brand="telegram"]:hover {
      background: #1a1a1a;
    }

    .social-links a[data-brand="github"] {
      background: #1a1a1a;
      color: white;
    }
    .social-links a[data-brand="github"]:hover {
      background: #FF6B35;
    }

    .social-links a[data-brand="vk"] {
      background: #4ECDC4;
      color: #1a1a1a;
    }
    .social-links a[data-brand="vk"]:hover {
      background: #1a1a1a;
      color: white;
    }

    .social-links a[data-brand="instagram"] {
      background: #FFE5EC;
      color: #1a1a1a;
    }
    .social-links a[data-brand="instagram"]:hover {
      background: #E4405F;
      color: white;
    }

    .social-links a[data-brand="twitter"] {
      background: #FFFBF5;
      color: #1a1a1a;
    }
    .social-links a[data-brand="twitter"]:hover {
      background: #1a1a1a;
      color: white;
    }

    .social-links a[data-brand="linkedin"] {
      background: #FFD93D;
      color: #1a1a1a;
    }
    .social-links a[data-brand="linkedin"]:hover {
      background: #1a1a1a;
      color: white;
    }

    /* Dark theme adjustments */
    :global([data-theme="dark"]) .social-links a[data-brand="github"] {
      background: #3d3d3d;
    }
    :global([data-theme="dark"]) .social-links a[data-brand="twitter"] {
      background: #2a2a2a;
      color: #FFFBF5;
    }
    :global([data-theme="dark"]) .social-links a[data-brand="twitter"]:hover {
      background: #FF8C5A;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .hero {
        padding: 2rem 1rem;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .subtitle {
        font-size: 1rem;
      }

      .about-images {
        flex-direction: column;
        align-items: center;
      }

      .about-images img {
        max-width: 100%;
      }

      .social-links a {
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
