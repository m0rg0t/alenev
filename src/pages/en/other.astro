---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Other Projects — Anton Lenev"
  description="VK Mini Apps, Yandex Alice skills, the Skull Pin jewelry brand, and mentoring by Anton Lenev."
>
  <h1>🎯 Other Projects</h1>

  <section class="section">
    <h2>VK Mini Apps</h2>
    <p class="intro-text">
      A collection of mini-apps for the VKontakte social network, including various entertainment and educational projects.
    </p>

    <div class="apps-grid">
      <article class="app-card">
        <h3>🔮 Tarot</h3>
        <p>Tarot card readings right inside VK</p>
        <a href="https://vk.com/app51769331?mid=4443423" target="_blank" rel="noopener">Open app</a>
      </article>

      <article class="app-card">
        <h3>⭐ Astroforecast</h3>
        <p>Astrological forecasts and horoscopes</p>
        <a href="https://vk.com/app51788038_4443423" target="_blank" rel="noopener">Open app</a>
      </article>

      <article class="app-card">
        <h3>💎 Magic Stones</h3>
        <p>Discover the properties of various gemstones</p>
        <a href="https://vk.com/app51896624_4443423" target="_blank" rel="noopener">Open app</a>
      </article>

      <article class="app-card">
        <h3>ᚱ Runes</h3>
        <p>Rune divination and their interpretation</p>
        <a href="https://vk.com/app51819171_4443423" target="_blank" rel="noopener">Open app</a>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Yandex Skills</h2>

    <article class="project">
      <h3>Bylina o Svyatogor</h3>
      <p>
        A voice skill for Yandex Alice narrating an ancient Russian bylina (epic tale) about the hero Svyatogor.
        Interactive storytelling with plot choice elements.
      </p>
      <a href="https://dialogs.yandex.ru/store/skills/b1d41565-bylina-o-svyatogor" target="_blank" rel="noopener">
        Open in Yandex Dialogs
      </a>
    </article>
  </section>

  <section class="section">
    <h2>Creative Projects</h2>

    <article class="project">
      <h3>Skull Pin Jewelry Brand</h3>
      <p>
        Unique hair accessories: clips, combs and other accessories created with 3D printing
        and traditional craft techniques.
      </p>
      <a href="https://vk.com/skull_pin" target="_blank" rel="noopener">VK Group</a>
    </article>
  </section>

  <section class="section">
    <h2>Charity</h2>

    <article class="project">
      <h3>Solvery — Mentor</h3>
      <p>
        Programming and development mentoring. I help beginner developers master the profession
        and solve complex technical problems.
      </p>
      <a href="https://solvery.io/ru/mentor/antonlenev" target="_blank" rel="noopener">Profile on Solvery</a>
    </article>
  </section>

  <style>
    /* Page Title */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .section {
      margin-bottom: 4rem;
    }

    .section h2 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    .intro-text {
      color: var(--color-text-muted);
      margin-bottom: 2rem;
      line-height: 1.6;
      text-transform: none;
    }

    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .app-card {
      background: var(--color-surface);
      padding: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      text-align: center;
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .app-card:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
    }

    .app-card:nth-child(1) { border-left: 6px solid var(--color-primary); }
    .app-card:nth-child(2) { border-left: 6px solid var(--color-accent); }
    .app-card:nth-child(3) { border-left: 6px solid var(--color-accent-alt); }
    .app-card:nth-child(4) { border-left: 6px solid var(--color-secondary); }

    :global([data-theme="dark"]) .app-card:nth-child(2) { border-left-color: var(--color-accent); }

    .app-card h3 {
      font-size: 1.3rem;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .app-card p {
      color: var(--color-text-muted);
      margin-bottom: 1rem;
      line-height: 1.6;
      text-transform: none;
    }

    .app-card a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .app-card a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    .project {
      background: var(--color-surface);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin-bottom: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .project:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
      border-left-color: var(--color-secondary);
    }

    .project h3 {
      font-size: 1.3rem;
      margin-bottom: 1rem;
      color: var(--color-text);
      text-transform: uppercase;
    }

    .project p {
      color: var(--color-text-muted);
      line-height: 1.8;
      margin-bottom: 1rem;
      text-transform: none;
    }

    .project a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .project a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      .apps-grid {
        grid-template-columns: 1fr;
      }

      .app-card, .project {
        box-shadow: 3px 3px 0 var(--color-border);
      }

      .app-card a, .project a {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }
    }
  </style>
</BaseLayout>
