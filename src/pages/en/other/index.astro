---
import { Picture } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import skullPinCover from '../../../assets/skull-pin/photo-1.jpg';
---

<BaseLayout
  title="Other Projects — Anton Lenev"
  description="VK Mini Apps, Yandex Alice skills, the Skull Pin jewelry brand, and mentoring by Anton Lenev."
>
  <h1>🎯 Other Projects</h1>

  <section class="section">
    <h2>Creative Projects</h2>

    <article class="project project-card">
      <a href="/en/other/skull-pin" class="cover-link" aria-label="Skull Pin — project page">
        <Picture
          src={skullPinCover}
          alt="Skull Pin accessory from the collection"
          formats={['avif', 'webp']}
          widths={[280, 560, 840]}
          sizes="(max-width: 640px) 100vw, 280px"
          class="cover"
          loading="lazy"
          decoding="async"
        />
      </a>
      <div class="card-body">
        <h3>"Skull Pin" Jewelry Brand</h3>
        <p>
          Unique hair and neck accessories — clips, combs, chokers and more — made with 3D printing and traditional craft techniques.
        </p>
        <div class="project-links">
          <a href="/en/other/skull-pin" class="btn-more">See more →</a>
          <a href="https://vk.com/skull_pin" target="_blank" rel="noopener">VK Group</a>
        </div>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Public Art & 3D Printing</h2>

    <article class="project">
      <h3>Kinetic sculptures on the streets of Rybinsk</h3>
      <p>
        A series of 3D-printed kinetic sculptures on a water theme, appearing on the embankments and in the parks of Rybinsk.
        The shapes are designed to "catch" the wind and rotate, producing a quasi-organic visual effect.
        This extends the <em>Rybinsk Secrets</em> series — small art objects waiting for passers-by in unexpected corners of the city.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=4443423&id=456240267&hash=d153a86b7aada30c&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="Kinetic sculptures — public art in Rybinsk"
          loading="lazy"
        ></iframe>
      </div>
      <div class="project-links">
        <a href="https://vk.com/wall4443423_2886" target="_blank" rel="noopener">Author's VK post</a>
        <a href="https://vk.com/wall4443423_2893" target="_blank" rel="noopener">Series continuation</a>
        <a href="https://vk.com/wall-114389229_92521" target="_blank" rel="noopener">"Taiyaki" café mention</a>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Early Adventures</h2>

    <article class="project">
      <h3>"Fuskin Cool Ottyak" — mock trailer about the demoscene (DiHalt, 2011)</h3>
      <p>
        A tongue-in-cheek teaser shot by the <em>CyberpunksUnity</em> crew over a couple of days
        for the Wild Compo at <strong>DiHalt 2011</strong> — a demoscene festival in Russia.
        The idea: make a trailer for an imaginary film about the rise of the demoscene in the Russian
        provinces. Shot improvised, with love for the demoscene, ZX Spectrum and the "ottyak" aesthetic.
        Anton Lenev played one of the roles.
      </p>
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/y2ymtaTPDUE"
          title="Fuskin Cool Ottyak — demoscene trailer"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div class="project-links">
        <a href="https://www.youtube.com/watch?v=y2ymtaTPDUE" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Charity</h2>

    <article class="project">
      <h3>Solvery — Mentor</h3>
      <p>
        Programming and development mentoring. I help beginner developers master the profession
        and solve complex technical problems.
      </p>
      <a href="https://solvery.io/ru/mentor/antonlenev" target="_blank" rel="noopener">Profile on Solvery</a>
    </article>
  </section>

  <style>
    /* Page Title */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .section {
      margin-bottom: 4rem;
    }

    .section h2 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    .intro-text {
      color: var(--color-text-muted);
      margin-bottom: 2rem;
      line-height: 1.6;
      text-transform: none;
    }

    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .app-card {
      background: var(--color-surface);
      padding: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      text-align: center;
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .app-card:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
    }

    .app-card:nth-child(1) { border-left: 6px solid var(--color-primary); }
    .app-card:nth-child(2) { border-left: 6px solid var(--color-accent); }
    .app-card:nth-child(3) { border-left: 6px solid var(--color-accent-alt); }
    .app-card:nth-child(4) { border-left: 6px solid var(--color-secondary); }

    :global([data-theme="dark"]) .app-card:nth-child(2) { border-left-color: var(--color-accent); }

    .app-card h3 {
      font-size: 1.3rem;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .app-card p {
      color: var(--color-text-muted);
      margin-bottom: 1rem;
      line-height: 1.6;
      text-transform: none;
    }

    .app-card a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .app-card a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    .project {
      background: var(--color-surface);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin-bottom: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .project:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
      border-left-color: var(--color-secondary);
    }

    .project h3 {
      font-size: 1.3rem;
      margin-bottom: 1rem;
      color: var(--color-text);
      text-transform: uppercase;
    }

    .project p {
      color: var(--color-text-muted);
      line-height: 1.8;
      margin-bottom: 1rem;
      text-transform: none;
    }

    .project a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .project a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    .project-card {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 1.5rem;
      align-items: start;
      padding: 0 !important;
      overflow: hidden;
    }

    .project-card .cover-link {
      display: block;
      padding: 0 !important;
      margin: 0 !important;
      background: transparent !important;
      box-shadow: none !important;
      border: none !important;
    }

    .project-card .cover-link picture {
      display: block;
      width: 100%;
      height: 100%;
    }

    .project-card .cover {
      width: 100%;
      height: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      display: block;
      border-right: var(--border-width) solid var(--color-border);
      transition: transform 0.2s ease;
    }

    .project-card .cover-link:hover .cover {
      transform: scale(1.03);
    }

    .project-card .card-body {
      padding: 1.5rem 1.5rem 1.5rem 0.5rem;
    }

    .project-card .btn-more {
      background: var(--color-accent) !important;
      color: #1a1a1a !important;
    }

    :global([data-theme="dark"]) .project-card .btn-more {
      color: #1a1a1a !important;
    }

    @media (max-width: 640px) {
      .project-card {
        grid-template-columns: 1fr;
      }
      .project-card .cover {
        aspect-ratio: 4 / 3;
        border-right: none;
        border-bottom: var(--border-width) solid var(--color-border);
      }
      .project-card .card-body {
        padding: 1.25rem;
      }
    }

    .project-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .video-embed {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      margin: 1rem 0;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 4px 4px 0 var(--color-border);
      background: #000;
    }

    .video-embed iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      .apps-grid {
        grid-template-columns: 1fr;
      }

      .app-card, .project {
        box-shadow: 3px 3px 0 var(--color-border);
      }

      .app-card a, .project a {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }
    }
  </style>
</BaseLayout>
