---
import { Picture } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import vkOffice1 from '../../assets/vk-office/vk-office-1.jpg';
import vkOffice2 from '../../assets/vk-office/vk-office-2.jpg';

const archives = await getCollection('archives');
const archivesByUrl = new Map(archives.map(a => [a.data.originalUrl, a.slug]));
---

<BaseLayout
  title="IT Projects — Anton Lenev"
  description="IT projects, programming talks and development experience by Anton Lenev — CTO/Frontend Developer, open-source contributor."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://alenev.ru/en/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'IT Projects', 'item': 'https://alenev.ru/en/it/' }
    ]
  })} />
  <h1>💻 IT Projects & Development</h1>

  <p class="page-intro">
    Anton Lenev is CTO and Frontend Developer at Viewst Inc and has been working in IT since 2011.
    <a href="/en/about">More about his career and education →</a>
  </p>

  <section class="section">
    <h2>Pet Projects</h2>

    <article class="project">
      <h3>OwlEye</h3>
      <p>
        Owl-shaped necklace jewelry that helps visually impaired people navigate closed spaces.
        During COVID-19 also helps maintain social distance.
      </p>
      <div class="links">
        <a href="https://owleye.space/" target="_blank" rel="noopener">Project Website</a>
        <a href="https://github.com/m0rg0t/OwlEye" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>Where is the local officer?</h3>
      <p>App for finding local police officers by address.</p>
      <div class="links">
        <a href="https://openpolice.ru/apps/pc-where-is-policeman/" target="_blank" rel="noopener">OpenPolice</a>
      </div>
    </article>

    <article class="project">
      <h3>Rybinsk City Day Poster</h3>
      <p>Design project — poster for Rybinsk City Day.</p>
      <div class="links">
        <a href="https://vk.com/wall-171301168_9014" target="_blank" rel="noopener">VKontakte post</a>
      </div>
    </article>

    <article class="project">
      <h3>Rybinsk Secrets (Рыбинские секретики)</h3>
      <p>A non-commercial city project: 3D-printed mascot figurines representing different Rybinsk districts (Vasilisa the Duck, Fyodor the Bear, Skomorokh the Fox, Engineer the Dog) with QR codes linking to a VK Mini App that "brings them to life," lets users collect them, and tells each district's story. First test launch in 2025.</p>
      <div class="links">
        <a href="https://vk.com/app53995977" target="_blank" rel="noopener">VK Mini App</a>
        <a href="https://vk.com/wall4443423_3186" target="_blank" rel="noopener">Author's announcement</a>
        <a href="https://vk.com/wall-111904385_97643" target="_blank" rel="noopener">Vesti Yaroslavl (video)</a>
        <a href="https://vk.com/wall-70020805_367739" target="_blank" rel="noopener">Rybinsk 40 TV (video)</a>
        {archivesByUrl.has("https://cheremuha.com/2025/08/18/vorobej-dlya-veretya-lis-dlya-skomoroxovoj-gory-v-gorode-poyavilis-rybinskie-sekretiki.html") && (
          <a href={`/archive/${archivesByUrl.get("https://cheremuha.com/2025/08/18/vorobej-dlya-veretya-lis-dlya-skomoroxovoj-gory-v-gorode-poyavilis-rybinskie-sekretiki.html")}`} class="archive-link">Cheremukha (archive)</a>
        )}
        {archivesByUrl.has("https://vesti-yaroslavl.ru/novosti/item/95879-na-ulitsakh-rybinska-ustanavlivayut-figurki-v-stile-personazhej-multfilmov") && (
          <a href={`/archive/${archivesByUrl.get("https://vesti-yaroslavl.ru/novosti/item/95879-na-ulitsakh-rybinska-ustanavlivayut-figurki-v-stile-personazhej-multfilmov")}`} class="archive-link">Vesti (archive)</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>js-url-downloader</h3>
      <p>JavaScript utility for batch-downloading files from a list of URLs.</p>
      <div class="links">
        <a href="https://github.com/m0rg0t/js-url-downloader" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>content-to-markdown-extension</h3>
      <p>Chrome/Edge extension that converts web pages and selected content into Markdown.</p>
      <div class="links">
        <a href="https://github.com/m0rg0t/content-to-markdown-extension" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>Flight search app</h3>
      <p>Windows Store app (legacy project).</p>
    </article>
  </section>

  <section class="section">
    <h2>VK Mini Apps</h2>
    <p class="page-intro" style="margin-bottom: 1.5rem;">
      Mini-apps for VKontakte — entertainment and educational projects.
    </p>

    <div class="apps-grid">
      <article class="app-card">
        <h3>🔮 Tarot</h3>
        <p>Tarot card readings right inside VK</p>
        <a href="https://vk.com/app51769331?mid=4443423" target="_blank" rel="noopener">Open app</a>
      </article>

      <article class="app-card">
        <h3>⭐ Astroforecast</h3>
        <p>Astrological forecasts and horoscopes</p>
        <a href="https://vk.com/app51788038_4443423" target="_blank" rel="noopener">Open app</a>
      </article>

      <article class="app-card">
        <h3>💎 Magic Stones</h3>
        <p>Discover the properties of various gemstones</p>
        <a href="https://vk.com/app51896624_4443423" target="_blank" rel="noopener">Open app</a>
      </article>

      <article class="app-card">
        <h3>ᚱ Runes</h3>
        <p>Rune divination and interpretation</p>
        <a href="https://vk.com/app51819171_4443423" target="_blank" rel="noopener">Open app</a>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Yandex Alice Skills</h2>

    <article class="project">
      <h3>Bylina o Svyatogor</h3>
      <p>
        A voice skill for the Yandex Alice smart speaker, narrating an ancient Russian bylina (epic tale) about the hero Svyatogor.
        Interactive storytelling with plot choice elements.
      </p>
      <div class="links">
        <a href="https://dialogs.yandex.ru/store/skills/b1d41565-bylina-o-svyatogor" target="_blank" rel="noopener">Open in Yandex Dialogs</a>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Talks/Presentations</h2>

    <article class="talk">
      <h3>"Strange Browser APIs" — Drinkup</h3>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=xdY7BrkbRUo&ab_channel=SPBFrontend" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>Features of mobile app development for Windows Phone and Windows 8</h3>
      <div class="links">
        <a href="https://youtu.be/t1tpZejtXGo?si=CfLFsdO79bmZbcN8" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>Will algorithms replace designers in advertising?</h3>
      <div class="links">
        <a href="https://www.youtube.com/live/MxjNTSK-UI4?si=UBY4zgtX6Y2NFdHi" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>EyeLens — Nokia Create Contest</h3>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=RGIRdYbMdaE" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>SIA Russia 2015 Finalist: EyeLens</h3>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=3kBqrkSM83s" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>IT Hobbyist — Tproger interview (video)</h3>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=kzzYJEoJXzo" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>"We need to go deeper: the road to WYSIWYG" — SPB Frontend Drinkup</h3>
      <p>Anton Lenev's talk at SPB Frontend Drinkup on the road to building an in-house WYSIWYG editor — the problems faced, how they were solved, and where it all led.</p>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=CEYy-knCG5w" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>"Where is the local officer?" — Windows Phone / Windows 8 app</h3>
      <p>Talk about the "Where is the local officer?" project — a Windows Phone and Windows 8 app built on openpolice.ru data.</p>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=HmDg23YXG5w" target="_blank" rel="noopener">Watch on YouTube</a>
      </div>
    </article>

    <article class="talk">
      <h3>VK Fresh Code 2023 — vlog by Vladilen Minin</h3>
      <p>Blogger Vladilen Minin shot a vlog covering the VK Fresh Code 2023 awards ceremony — a test-drive of the winners' mini-apps (including Anton's projects) and a behind-the-scenes look at the contest.</p>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=jjVvxWlKwZc" target="_blank" rel="noopener">Watch on YouTube</a>
        <a href="https://vk.com/wall-166562603_6616" target="_blank" rel="noopener">VK post</a>
      </div>
    </article>

    <article class="talk">
      <h3>Stream: Obsidian plugin and "React is not needed"</h3>
      <p>A stream featuring Anton Lenev on building an Obsidian plugin and the discussion around whether React is always the right frontend choice.</p>
      <div class="links">
        <a href="https://vk.com/video220730549_456239696" target="_blank" rel="noopener">Watch on VK Video</a>
      </div>
    </article>

    <article class="talk">
      <h3>VK Mini Apps podcast: a developer's path and mini-apps without a technical background</h3>
      <p>
        Podcast by the VK Mini Apps team with Anton Lenev — VK Fresh Code 2023 winner, creator of four VK services and CTO at Viewst.
        Topics: building quality mini-apps without a technical background, the CTO role in a startup, and juggling projects without slipping into perfectionism. Bonus: a prediction for VK Fresh Code 2024.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=-166562603&id=456239313&hash=7bcc88cd4b1834b0&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="VK Mini Apps podcast with Anton Lenev"
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="https://vk.com/wall-166562603_8087" target="_blank" rel="noopener">VK post</a>
        <a href="https://vk.com/video-166562603_456239313" target="_blank" rel="noopener">Video on VK</a>
      </div>
    </article>

    <article class="talk">
      <h3>Behind the scenes: VK Mini Apps podcast shoot</h3>
      <p>A short BTS clip from the VK Mini Apps podcast shoot with Anton Lenev.</p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=-166562603&id=456239315&hash=aee7dcbed97f22b7&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="Behind the scenes: VK Mini Apps podcast"
          loading="lazy"
        ></iframe>
      </div>
      <div class="photos-row">
        <Picture src={vkOffice1} alt="Anton Lenev at VK office, May 2024" formats={['avif', 'webp']} widths={[440, 880]} sizes="(min-width: 640px) 440px, 100vw" loading="lazy" decoding="async" />
        <Picture src={vkOffice2} alt="Anton Lenev at VK office" formats={['avif', 'webp']} widths={[440, 880]} sizes="(min-width: 640px) 440px, 100vw" loading="lazy" decoding="async" />
      </div>
      <div class="links">
        <a href="https://vk.com/wall-166562603_8107" target="_blank" rel="noopener">VK post (BTS)</a>
        <a href="https://vk.com/wall4443423_3028" target="_blank" rel="noopener">Anton's post from VK office</a>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Hackathons, Contests & Grants</h2>
    <p class="page-intro" style="margin-bottom: 1.5rem;">
      Confirmed participations and wins across developer hackathons, app contests, and grant programs.
    </p>

    <article class="project">
      <h3>🏆 VK Dev Grants 2025 — winner with "Otredach"</h3>
      <p>The AI-powered VK Mini App "Otredach" won the VK Dev Grants 2025 grant program for mini-app developers.</p>
      <div class="links">
        <a href="https://vk.com/press/dev-2025" target="_blank" rel="noopener">VK Press Release</a>
        <a href="https://habr.com/ru/companies/vk/articles/1011864/" target="_blank" rel="noopener">Article on Habr</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 VK Fresh Code 2023 — winner (and the awards ceremony)</h3>
      <p>
        Anton Lenev was one of the winners of the VK Fresh Code 2023 grant competition for new VK Mini App developers.
        Unlike the usual business-suits-and-serious-faces ceremony, this one followed VK's signature style — see the video below.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=-166562603&id=456239170&hash=58bbebae8a77a58d&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="VK Fresh Code 2023 awards ceremony"
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="https://vk.com/wall-166562603_6228" target="_blank" rel="noopener">VK post</a>
        <a href="https://vk.com/video-166562603_456239170" target="_blank" rel="noopener">Video on VK</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 VK Fresh Code 2024 — winner with "Coffee Grounds"</h3>
      <p>The "Coffee Grounds" app won the VK Fresh Code 2024 grant competition for new VK Mini App developers.</p>
      <div class="links">
        <a href="https://vk.com/press/freshcode-2024-results" target="_blank" rel="noopener">VK Press Release</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 VK Mini Apps article contest — winner</h3>
      <p>"VK Mini Apps: Signature Verification and Node.js" won the platform's article contest.</p>
      <div class="links">
        <a href="https://vk.com/@4443423-vk-mini-apps-proverka-podpisi-i-nodejs" target="_blank" rel="noopener">Article</a>
        <a href="https://vk.com/wall-166562603_9332" target="_blank" rel="noopener">Win announcement</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 BudgetApps 2015 — winner in the Yandex category</h3>
      <p>
        "Where is a Good Place to Live?" took 1st place in the Yandex category of the Russian Ministry of Finance BudgetApps open financial data contest.
        The web service estimated how attractive a district was for living based on social infrastructure and open public procurement data.
      </p>
      <div class="links">
        {archivesByUrl.has("https://minfin.gov.ru/ru/document?id_4=113821-opredeleny_pobediteli_konkursa_minfina_rossii_na_otkrytykh_finansovykh_dannykh_budgetapps") && (
          <a href={`/archive/${archivesByUrl.get("https://minfin.gov.ru/ru/document?id_4=113821-opredeleny_pobediteli_konkursa_minfina_rossii_na_otkrytykh_finansovykh_dannykh_budgetapps")}`}>Ministry of Finance archive</a>
        )}
        {archivesByUrl.has("https://apptractor.ru/info/interview/anton-lenev-gde-zhit-horosho-o-konkurse-budgetapps.html") && (
          <a href={`/archive/${archivesByUrl.get("https://apptractor.ru/info/interview/anton-lenev-gde-zhit-horosho-o-konkurse-budgetapps.html")}`}>AppTractor archive</a>
        )}
        {archivesByUrl.has("https://gazeta-rybinsk.ru/2015/04/29/18147") && (
          <a href={`/archive/${archivesByUrl.get("https://gazeta-rybinsk.ru/2015/04/29/18147")}`}>Gazeta Rybinsk archive</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>🏅 Social Impact Award Russia 2015 — finalist with EyeLens</h3>
      <p>
        EyeLens, an app for visually impaired users and people with color vision deficiency, reached the finals of Social Impact Award Russia 2015.
      </p>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=3kBqrkSM83s" target="_blank" rel="noopener">Finalist video</a>
      </div>
    </article>

    <article class="project">
      <h3>🏅 Nokia Create Contest — finalist with EyeLens</h3>
      <p>
        EyeLens participated in Nokia Create as a Windows Phone project helping visually impaired and color-blind users.
      </p>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=RGIRdYbMdaE" target="_blank" rel="noopener">Project presentation</a>
      </div>
    </article>

    <article class="project">
      <h3>🏅 Junction 2020 — OwlEye prototype</h3>
      <p>
        The first OwlEye prototype was built for Junction 2020: a "parking sensor for humans" shaped as an owl necklace,
        using an ultrasonic distance sensor, vibration, and sound alerts to warn about nearby obstacles.
      </p>
      <div class="links">
        <a href="https://habr.com/ru/articles/754234/" target="_blank" rel="noopener">Article on Habr</a>
        <a href="https://github.com/m0rg0t/OwlEye" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>🏅 Moscow Government Hackathon 2014 — "Where is a Good Place to Live?"</h3>
      <p>
        Anton presented "Where is a Good Place to Live?" at a two-day hackathon for mobile apps and web services based on Moscow open data.
      </p>
      <div class="links">
        {archivesByUrl.has("https://www.m24.ru/videos/svyaz/27042014/50447") && (
          <a href={`/archive/${archivesByUrl.get("https://www.m24.ru/videos/svyaz/27042014/50447")}`}>M24 archive</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>🏆 PayPal Battle Hack Moscow 2013 — Ecwid special prize</h3>
      <p>
        Profit Button received Ecwid's special prize at PayPal Battle Hack 2013 in Moscow for a solution that let mobile apps embed
        an e-commerce widget without changing the app's design or code.
      </p>
      <div class="links">
        {archivesByUrl.has("https://spark.ru/startup/profitbutton/blog/549/pobeda-komandi-profit-button-na-paypal-battle-hack-moscow") && (
          <a href={`/archive/${archivesByUrl.get("https://spark.ru/startup/profitbutton/blog/549/pobeda-komandi-profit-button-na-paypal-battle-hack-moscow")}`}>Spark archive</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>🏅 HackPoint 3.0 — regional hackathon in Cherepovets (2014)</h3>
      <p>
        Participation in the HackPoint 3.0 regional hackathon in Cherepovets (October 17–19, 2014). 48 hours to build
        prototypes — mobile apps and web services. Recap video published by the organizers in December 2014.
      </p>
      <div class="links">
        <a href="https://vk.com/wall-51121552_949" target="_blank" rel="noopener">VK post</a>
        <a href="https://www.youtube.com/watch?v=lkO7DcZPaWU" target="_blank" rel="noopener">Recap video</a>
        {archivesByUrl.has("https://vk.com/wall-51121552_949") && (
          <a href={`/archive/${archivesByUrl.get("https://vk.com/wall-51121552_949")}`}>Archive</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>🏆 OpenPolice 2013 — 2nd place with "Where is the local officer?"</h3>
      <p>
        "Where is the local officer?", a Windows Phone app, took 2nd place in the Mobile App category of the OpenPolice contest.
        According to Polit.ru, the project also grew out of a two-day hackathon where it became one of the laureates.
      </p>
      <div class="links">
        <a href="https://polit.ru/articles/strana/gde-uchastkovyy-2013-07-04/" target="_blank" rel="noopener">Polit.ru</a>
        {archivesByUrl.has("https://www.youtube.com/watch?v=HmDg23YXG5w") && (
          <a href={`/archive/${archivesByUrl.get("https://www.youtube.com/watch?v=HmDg23YXG5w")}`}>Talk archive</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>🏆 Tinkoff Competition (3rd place, 2013) — Windows Phone app</h3>
      <p>Award ceremony for a Windows Phone app at the Tinkoff Bank competition.</p>
