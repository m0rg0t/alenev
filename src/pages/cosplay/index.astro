---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CostumeCard from '../../components/CostumeCard.astro';
import EventCard from '../../components/EventCard.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('ru');

const costumes = (await getCollection('costumes'))
  .filter(entry => entry.data.lang === 'ru')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const events = (await getCollection('cosplay-events'))
  .filter(entry => entry.data.lang === 'ru')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// For events, resolve costume titles
const allCostumes = (await getCollection('costumes'))
  .filter(entry => entry.data.lang === 'ru');

function getCostumeTitles(costumeSlugs: string[]): string[] {
  return costumeSlugs.map(slug => {
    const found = allCostumes.find(c => c.data.costumeId === slug);
    return found?.data.title ?? slug;
  });
}
---

<BaseLayout
  title="Косплей - Антон Ленев"
  description="Косплей-портфолио Антона Ленева: костюмы Айзека Кларка из Dead Space, Mass Effect, Skyrim, Хищника и другие. Процесс создания, материалы, фотосессии и события."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Главная', 'item': 'https://alenev.ru/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Косплей', 'item': 'https://alenev.ru/cosplay/' }
    ]
  })} />
  <h1>{t('cosplay.title')}</h1>

  <section class="intro">
    <p class="lead">
      Коллекция косплей-проектов Антона Ленева — костюмы по мотивам Dead Space, Mass Effect,
      Skyrim, Overwatch, Хищника и русских сказок. В работе сочетаются EVA-фоам, 3D-печать,
      электроника и подсветка. Костюм Айзека Кларка из Dead Space — один из самых
      технически сложных проектов, получивший публикации на Habr, DTF и Instructables.
      <a href="/about">Подробнее об Антоне →</a>
    </p>
  </section>

  <section class="costumes-section">
    <h2>{t('cosplay.costumes')}</h2>
    <div class="costumes-grid">
      {costumes.map(costume => (
        <CostumeCard
          title={costume.data.title}
          slug={costume.data.costumeId}
          coverImage={costume.data.coverImage}
          character={costume.data.character}
          franchise={costume.data.franchise}
          lang="ru"
        />
      ))}
    </div>
  </section>

  {events.length > 0 && (
    <section class="events-section">
      <h2>{t('cosplay.events')}</h2>
      <div class="events-grid">
        {events.map(event => (
          <EventCard
            title={event.data.title}
            slug={event.data.costumeId}
            coverImage={event.data.coverImage}
            date={event.data.date?.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long' })}
            location={event.data.location}
            costumeTitles={getCostumeTitles(event.data.costumes)}
            lang="ru"
          />
        ))}
      </div>
    </section>
  )}

  <section class="awards-section">
    <h2>Награды и победы</h2>

    <article class="video-article">
      <h3>🏆 Гран-при фестиваля «Поход за Солнцем 2018» (Самара)</h3>
      <p>
        На фестивале «Поход за Солнцем 2018» в Самаре проект Антона Ленева по Overwatch (персонаж — McCree) получил
        <strong>Гран-при</strong> по мнению спонсора фестиваля <em>«Game &amp; Reality»</em>.
        Фото: Слава Гребёнкин (Рыбинск / Москва).
      </p>
      <div class="links">
        <a href="https://vk.com/wall-21253509_21745" target="_blank" rel="noopener">Пост ВКонтакте</a>
      </div>
    </article>

    <article class="video-article">
      <h3>🏆 «Охтакон 2020» — номинация «Лучший косплей» (Санкт-Петербург)</h3>
      <p>
        На финале конкурса косплея фестиваля «Охтакон» в ТЦ «Охта молл» (Санкт-Петербург, 7 марта 2020) Антон Ленев
        победил в номинации <strong>«Лучший косплей»</strong> в образе Тора из фильма «Тор: Рагнарёк». В конкурсе
        участвовало 28 человек из разных городов России, в финал вышли 12. Репортаж — Tribuna.ee, автор Арсений Денисов.
      </p>
      <div class="links">
        <a href="https://tribuna.ee/attributes/kosplay/" target="_blank" rel="noopener">Tribuna.ee</a>
        <a href="/archive/tribuna-ohtakon-2020">Архив</a>
      </div>
    </article>

    <article class="video-article">
      <h3>🏆 Карьерный таймлайн побед (по анонсу ASIAVOL [V] 2019)</h3>
      <p>
        Список побед на конкурсной программе различных фестивалей, опубликованный организаторами
        ASIAVOL [V] 2019 при анонсе Антона в качестве члена жюри:
      </p>
      <ul>
        <li><strong>АваЭкспо 2015</strong> — спецприз от фестиваля Ucon (костюм Довакина, Skyrim)</li>
        <li><strong>FAP 2015</strong> — 1 место в дефиле «Space Opera» (костюм Шепарда, Mass Effect)</li>
        <li><strong>FAP 2016</strong> — 1 место в «западном» дефиле и приз зрительских симпатий</li>
        <li><strong>Starcon 2016</strong> — спецприз</li>
        <li><strong>FanFan 2018</strong> — спецприз</li>
      </ul>
      <p>
        Антон также является постоянным участником фестивалей <em>Игромир, ComicCon Russia,
        Старкон, АваЭкспо</em> и <em>FAP</em>.
      </p>
      <div class="links">
        <a href="https://vk.com/wall-172806430_919" target="_blank" rel="noopener">Анонс ASIAVOL [V] 2019 ВКонтакте</a>
      </div>
    </article>
  </section>

  <section class="videos-section">
    <h2>Видео и стримы</h2>

    <article class="video-article">
      <h3>Вечерний стрим: косплей с Антоном Ленёвым (Рыбинск, 2019)</h3>
      <p>
        Стрим «17:40» из Рыбинска — гость Антон Ленёв. Разговор о косплее: костюмы, материалы, мероприятия и путь в сообщество.
      </p>
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/E6M5PwOPUUI"
          title="Косплей / гость Антон Ленёв / Вечерний стрим 17:40"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="/archive/cosplay-stream-2019">Текстовая версия →</a>
        <a href="https://www.youtube.com/watch?v=E6M5PwOPUUI" target="_blank" rel="noopener">Смотреть на YouTube</a>
      </div>
    </article>

    <p class="see-more-note">
      Видео по конкретным костюмам смотрите на странице костюма, например <a href="/cosplay/mccree">Маккри (Overwatch)</a>.
    </p>
  </section>

  <style>
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .intro {
      margin-bottom: 3rem;
    }

    .lead {
      font-size: 1.2rem;
      line-height: 1.8;
      color: var(--color-text);
      background: var(--color-surface);
      padding: 2rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .lead a {
      color: var(--color-primary-dark);
      text-decoration: underline;
      font-weight: 700;
    }

    .lead a:hover {
      color: var(--color-secondary);
    }

    :global([data-theme="dark"]) .lead a {
      color: var(--color-accent);
    }

    .costumes-section,
    .events-section {
      margin-bottom: 4rem;
    }

    h2 {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    .events-section h2 {
      background: var(--color-accent-alt);
      color: var(--color-text);
    }

    :global([data-theme="dark"]) .events-section h2 {
      color: #1a1a1a;
    }

    .costumes-grid,
    .events-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .videos-section,
    .awards-section {
      margin-bottom: 4rem;
    }

    .awards-section h2 {
      background: var(--color-accent-alt);
      color: var(--color-text);
    }

    :global([data-theme="dark"]) .awards-section h2 {
      color: #1a1a1a;
    }

    .videos-section h2 {
      background: var(--color-accent);
      color: var(--color-text);
    }

    :global([data-theme="dark"]) .videos-section h2 {
      color: #1a1a1a;
    }

    .video-article {
      background: var(--color-surface);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin-bottom: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .video-article h3 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      color: var(--color-text);
    }

    .video-article p {
      color: var(--color-text-muted);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .video-embed {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      margin: 1rem 0;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 4px 4px 0 var(--color-border);
      background: #000;
    }

    .video-embed iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .video-article .links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .video-article .links a {
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .video-article .links a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      .costumes-grid,
      .events-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
