---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import vkOffice1 from '../assets/vk-office/vk-office-1.jpg';
import vkOffice2 from '../assets/vk-office/vk-office-2.jpg';

const archives = await getCollection('archives');
const archivesByUrl = new Map(archives.map(a => [a.data.originalUrl, a.slug]));

// TODO: fill in `uploadDate` (YYYY-MM-DD) for each talk to enable Google video rich results.
const talks = [
  {
    name: 'Странное браузерное API — Дринкап',
    description: 'Доклад Антона Ленева на встрече SPB Frontend Drinkup о малоизвестных и необычных браузерных API.',
    videoId: 'xdY7BrkbRUo',
    url: 'https://www.youtube.com/watch?v=xdY7BrkbRUo&ab_channel=SPBFrontend',
    embedUrl: 'https://www.youtube.com/embed/xdY7BrkbRUo',
    uploadDate: '', // TODO
  },
  {
    name: 'Особенности разработки мобильных приложений для Windows Phone и Windows 8',
    description: 'Доклад Антона Ленева о разработке мобильных приложений для платформ Windows Phone и Windows 8.',
    videoId: 't1tpZejtXGo',
    url: 'https://youtu.be/t1tpZejtXGo',
    embedUrl: 'https://www.youtube.com/embed/t1tpZejtXGo',
    uploadDate: '', // TODO
  },
  {
    name: 'Заменят ли алгоритмы дизайнеров в рекламе?',
    description: 'Доклад Антона Ленева о применении алгоритмов и ИИ в рекламном дизайне.',
    videoId: 'MxjNTSK-UI4',
    url: 'https://www.youtube.com/live/MxjNTSK-UI4',
    embedUrl: 'https://www.youtube.com/embed/MxjNTSK-UI4',
    uploadDate: '', // TODO
  },
  {
    name: 'EyeLens — Nokia Create Contest',
    description: 'Презентация проекта EyeLens (приложение для слабовидящих и людей с нарушениями цветовосприятия) в рамках конкурса Nokia Create.',
    videoId: 'RGIRdYbMdaE',
    url: 'https://www.youtube.com/watch?v=RGIRdYbMdaE',
    embedUrl: 'https://www.youtube.com/embed/RGIRdYbMdaE',
    uploadDate: '',
  },
  {
    name: 'SIA Russia 2015 Finalist: EyeLens',
    description: 'Финалистский ролик проекта EyeLens в рамках Social Impact Award Russia 2015.',
    videoId: '3kBqrkSM83s',
    url: 'https://www.youtube.com/watch?v=3kBqrkSM83s',
    embedUrl: 'https://www.youtube.com/embed/3kBqrkSM83s',
    uploadDate: '2015',
  },
  {
    name: 'Хобби айтишника: Tproger-интервью (видеоверсия)',
    description: 'Видеоверсия интервью Антона Ленева на Tproger о косплее, 3D-печати и озвучке аудиокниг.',
    videoId: 'kzzYJEoJXzo',
    url: 'https://www.youtube.com/watch?v=kzzYJEoJXzo',
    embedUrl: 'https://www.youtube.com/embed/kzzYJEoJXzo',
    uploadDate: '2025-09-02',
  },
  {
    name: 'We need to go deeper: куда нас привела дорога к WYSIWYG — SPB Frontend Drinkup',
    description: 'Доклад Антона Ленева на встрече SPB Frontend Drinkup о пути к собственному WYSIWYG-редактору: с какими проблемами столкнулись, как их решали и куда это их привело.',
    videoId: 'CEYy-knCG5w',
    url: 'https://www.youtube.com/watch?v=CEYy-knCG5w',
    embedUrl: 'https://www.youtube.com/embed/CEYy-knCG5w',
    uploadDate: '',
  },
  {
    name: '«Где участковый?»: приложение для Windows Phone и Windows 8',
    description: 'Доклад Антона Ленева о проекте «Где участковый?» — приложении для Windows Phone и Windows 8 на основе данных openpolice.ru.',
    videoId: 'HmDg23YXG5w',
    url: 'https://www.youtube.com/watch?v=HmDg23YXG5w',
    embedUrl: 'https://www.youtube.com/embed/HmDg23YXG5w',
    uploadDate: '',
  },
  {
    name: 'VK Fresh Code 2023 — влог Владилена Минина',
    description: 'Блогер Владилен Минин снял влог о церемонии награждения VK Fresh Code 2023: тест-драйв мини-приложений победителей, включая проекты Антона Ленева, и закулисье конкурса.',
    videoId: 'jjVvxWlKwZc',
    url: 'https://www.youtube.com/watch?v=jjVvxWlKwZc',
    embedUrl: 'https://www.youtube.com/embed/jjVvxWlKwZc',
    uploadDate: '2023',
  },
];

const videoSchemas = talks.map(t => {
  const schema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    'name': t.name,
    'description': t.description,
    'thumbnailUrl': `https://img.youtube.com/vi/${t.videoId}/hqdefault.jpg`,
    'contentUrl': t.url,
    'embedUrl': t.embedUrl,
    'author': { '@id': 'https://alenev.ru/#person' },
    'inLanguage': 'ru',
  };
  if (t.uploadDate) schema.uploadDate = t.uploadDate;
  return schema;
});
---

<BaseLayout
  title="IT Проекты - Антон Ленев"
  description="IT-проекты, выступления и опыт разработки Антона Ленева — CTO/Frontend Developer, контрибьютор открытого кода. OwlEye, Skull Pin, доклады SPBFrontend."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://alenev.ru/" },
      { "@type": "ListItem", "position": 2, "name": "IT Проекты", "item": "https://alenev.ru/it/" }
    ]
  })} />
  {videoSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
  <h1>💻 IT Проекты и Разработка</h1>

  <p class="page-intro">
    Антон Ленев — CTO и Frontend Developer в Viewst Inc, в IT с 2011 года.
    <a href="/about">Подробнее о карьере и образовании →</a>
  </p>

  <section class="section">
    <h2>Pet Проекты</h2>

    <article class="project">
      <h3>OwlEye</h3>
      <p>
        Украшение-ожерелье в виде совы, помогающее слабовидящим людям ориентироваться в закрытых пространствах.
        Во время COVID-19 также помогает соблюдать социальную дистанцию.
      </p>
      <div class="links">
        <a href="https://owleye.space/" target="_blank" rel="noopener">Сайт проекта</a>
        <a href="https://github.com/m0rg0t/OwlEye" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>Где участковый?</h3>
      <p>Приложение для поиска участковых по адресу.</p>
      <div class="links">
        <a href="https://openpolice.ru/apps/pc-where-is-policeman/" target="_blank" rel="noopener">OpenPolice</a>
      </div>
    </article>

    <article class="project">
      <h3>Афиша Дня города Рыбинска</h3>
      <p>Дизайн-проект афиши к Дню города Рыбинска.</p>
      <div class="links">
        <a href="https://vk.com/wall-171301168_9014" target="_blank" rel="noopener">Пост ВКонтакте</a>
      </div>
    </article>

    <article class="project">
      <h3>Рыбинские секретики</h3>
      <p>Городской некоммерческий проект: 3D-печатные фигурки-маскоты по районам Рыбинска (Уточка Василиса, Медведь Фёдор, Лис Скоморох, Пёс Инженер) с QR-кодами и мини-приложением VK, которое «оживляет» персонажей, помогает собирать коллекцию и рассказывает о достопримечательностях. Первый тестовый запуск — 2025.</p>
      <div class="links">
        <a href="https://vk.com/app53995977" target="_blank" rel="noopener">VK Mini App</a>
        <a href="https://vk.com/wall4443423_3186" target="_blank" rel="noopener">Анонс автора</a>
        <a href="https://vk.com/wall-111904385_97643" target="_blank" rel="noopener">Вести Ярославль (видео)</a>
        <a href="https://vk.com/wall-70020805_367739" target="_blank" rel="noopener">Рыбинск 40 (видео)</a>
        {archivesByUrl.has("https://cheremuha.com/2025/08/18/vorobej-dlya-veretya-lis-dlya-skomoroxovoj-gory-v-gorode-poyavilis-rybinskie-sekretiki.html") && (
          <a href={`/archive/${archivesByUrl.get("https://cheremuha.com/2025/08/18/vorobej-dlya-veretya-lis-dlya-skomoroxovoj-gory-v-gorode-poyavilis-rybinskie-sekretiki.html")}`} class="archive-link">Черёмуха (архив)</a>
        )}
        {archivesByUrl.has("https://vesti-yaroslavl.ru/novosti/item/95879-na-ulitsakh-rybinska-ustanavlivayut-figurki-v-stile-personazhej-multfilmov") && (
          <a href={`/archive/${archivesByUrl.get("https://vesti-yaroslavl.ru/novosti/item/95879-na-ulitsakh-rybinska-ustanavlivayut-figurki-v-stile-personazhej-multfilmov")}`} class="archive-link">Вести (архив)</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>js-url-downloader</h3>
      <p>Утилита на JavaScript для пакетной загрузки файлов по списку URL.</p>
      <div class="links">
        <a href="https://github.com/m0rg0t/js-url-downloader" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>content-to-markdown-extension</h3>
      <p>Расширение Chrome/Edge для конвертации страниц и выделенного контента в Markdown.</p>
      <div class="links">
        <a href="https://github.com/m0rg0t/content-to-markdown-extension" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>Поиск авиабилетов</h3>
      <p>Приложение для Windows Store (устаревший проект).</p>
    </article>
  </section>

  <section class="section">
    <h2>VK Mini Apps</h2>
    <p class="page-intro" style="margin-bottom: 1.5rem;">
      Мини-приложения для ВКонтакте — развлекательные и познавательные проекты.
    </p>

    <div class="apps-grid">
      <article class="app-card">
        <h3>🔮 Таро</h3>
        <p>Гадание на картах Таро прямо в VK</p>
        <a href="https://vk.com/app51769331?mid=4443423" target="_blank" rel="noopener">Открыть приложение</a>
      </article>

      <article class="app-card">
        <h3>⭐ Астропрогноз</h3>
        <p>Астрологические прогнозы и гороскопы</p>
        <a href="https://vk.com/app51788038_4443423" target="_blank" rel="noopener">Открыть приложение</a>
      </article>

      <article class="app-card">
        <h3>💎 Магические камни</h3>
        <p>Узнайте о свойствах различных камней</p>
        <a href="https://vk.com/app51896624_4443423" target="_blank" rel="noopener">Открыть приложение</a>
      </article>

      <article class="app-card">
        <h3>ᚱ Руны</h3>
        <p>Гадание на рунах и их толкование</p>
        <a href="https://vk.com/app51819171_4443423" target="_blank" rel="noopener">Открыть приложение</a>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Навыки для Яндекс.Алисы</h2>

    <article class="project">
      <h3>Былина о Святогоре</h3>
      <p>
        Голосовой навык для умной колонки Яндекс.Алиса, рассказывающий древнерусскую былину о богатыре Святогоре.
        Интерактивное повествование с элементами выбора развития сюжета.
      </p>
      <div class="links">
        <a href="https://dialogs.yandex.ru/store/skills/b1d41565-bylina-o-svyatogor" target="_blank" rel="noopener">Открыть в Яндекс.Диалогах</a>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Выступления</h2>

    {talks.map(talk => (
      <article class="talk">
        <h3>{talk.name}</h3>
        <p>{talk.description}</p>
        <div class="links">
          <a href={talk.url} target="_blank" rel="noopener">Смотреть на YouTube</a>
        </div>
      </article>
    ))}

    <article class="talk">
      <h3>Стрим: плагин для Obsidian и «почему React не нужен»</h3>
      <p>Стрим с участием Антона Ленева о разработке плагина для Obsidian и обсуждение тезиса, что React не всегда нужен во фронтенде.</p>
      <div class="links">
        <a href="https://vk.com/video220730549_456239696" target="_blank" rel="noopener">Смотреть в VK Видео</a>
      </div>
    </article>

    <article class="talk">
      <h3>Подкаст VK Mini Apps: путь разработчика и мини-приложения без технического бэкграунда</h3>
      <p>
        Подкаст команды VK Mini Apps с Антоном Ленёвым — победителем VK Fresh Code 2023, создателем четырёх сервисов ВКонтакте и CTO Viewst.
        Обсудили возможность делать качественные мини-приложения без технического бэкграунда, роль CTO в стартапе и как совмещать проекты, не скатываясь в перфекционизм. Бонус — предсказание на VK Fresh Code 2024.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=-166562603&id=456239313&hash=7bcc88cd4b1834b0&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="Подкаст VK Mini Apps с Антоном Ленёвым"
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="https://vk.com/wall-166562603_8087" target="_blank" rel="noopener">Пост ВКонтакте</a>
        <a href="https://vk.com/video-166562603_456239313" target="_blank" rel="noopener">Видео в VK</a>
      </div>
    </article>

    <article class="talk">
      <h3>Закулисье съёмки подкаста VK Mini Apps</h3>
      <p>
        Короткий ролик о процессе съёмки подкаста с Антоном Ленёвым: как всё устроено за кадром.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=-166562603&id=456239315&hash=aee7dcbed97f22b7&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="Закулисье подкаста VK Mini Apps"
          loading="lazy"
        ></iframe>
      </div>
      <div class="photos-row">
        <Picture src={vkOffice1} alt="Антон Ленев в офисе ВКонтакте, май 2024" formats={['avif', 'webp']} widths={[440, 880]} sizes="(min-width: 640px) 440px, 100vw" loading="lazy" decoding="async" />
        <Picture src={vkOffice2} alt="Антон Ленев в офисе ВКонтакте" formats={['avif', 'webp']} widths={[440, 880]} sizes="(min-width: 640px) 440px, 100vw" loading="lazy" decoding="async" />
      </div>
      <div class="links">
        <a href="https://vk.com/wall-166562603_8107" target="_blank" rel="noopener">Пост ВКонтакте (закулисье)</a>
        <a href="https://vk.com/wall4443423_3028" target="_blank" rel="noopener">Пост Антона из офиса ВК</a>
      </div>
    </article>
  </section>

  <section class="section">
    <h2>Хакатоны, конкурсы и гранты</h2>
    <p class="page-intro" style="margin-bottom: 1.5rem;">
      Подборка подтверждённых участий и побед в разработческих хакатонах, конкурсах приложений и грантовых программах.
    </p>

    <article class="project">
      <h3>🏆 VK Dev Grants 2025 — победитель с проектом «Отредач»</h3>
      <p>AI-проект «Отредач» (VK Mini App) победил в грантовой программе VK Dev Grants 2025 для разработчиков мини-приложений.</p>
      <div class="links">
        <a href="https://vk.com/press/dev-2025" target="_blank" rel="noopener">Пресс-релиз VK</a>
        <a href="https://habr.com/ru/companies/vk/articles/1011864/" target="_blank" rel="noopener">Статья на Хабр</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 VK Fresh Code 2023 — победитель (и церемония награждения)</h3>
      <p>
        Антон Ленёв — один из победителей грантового конкурса VK Fresh Code 2023 для начинающих разработчиков VK Mini Apps.
        В отличие от «деловых костюмов и серьёзных лиц», церемония прошла в своём узнаваемом стиле — видео ниже.
      </p>
      <div class="video-embed">
        <iframe
          src="https://vk.com/video_ext.php?oid=-166562603&id=456239170&hash=58bbebae8a77a58d&hd=2"
          width="853"
          height="480"
          frameborder="0"
          allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
          allowfullscreen
          title="Церемония награждения VK Fresh Code 2023"
          loading="lazy"
        ></iframe>
      </div>
      <div class="links">
        <a href="https://vk.com/wall-166562603_6228" target="_blank" rel="noopener">Пост ВКонтакте</a>
        <a href="https://vk.com/video-166562603_456239170" target="_blank" rel="noopener">Видео в VK</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 VK Fresh Code 2024 — победитель с проектом «Кофейная гуща»</h3>
      <p>Приложение «Кофейная гуща» победило в грантовом конкурсе VK Fresh Code 2024 для начинающих разработчиков VK Mini Apps.</p>
      <div class="links">
        <a href="https://vk.com/press/freshcode-2024-results" target="_blank" rel="noopener">Пресс-релиз VK</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 Конкурс статей о VK Mini Apps — победитель</h3>
      <p>Статья «VK Mini Apps: проверка подписи и Node.js» победила в конкурсе статей о платформе VK Mini Apps.</p>
      <div class="links">
        <a href="https://vk.com/@4443423-vk-mini-apps-proverka-podpisi-i-nodejs" target="_blank" rel="noopener">Статья</a>
        <a href="https://vk.com/wall-166562603_9332" target="_blank" rel="noopener">Анонс победы</a>
      </div>
    </article>

    <article class="project">
      <h3>🏆 BudgetApps 2015 — победитель в номинации «Яндекс»</h3>
      <p>
        Проект «Где жить хорошо?» занял 1 место в номинации «Яндекс» конкурса Минфина России на открытых финансовых данных BudgetApps.
        Веб-сервис оценивал привлекательность района для жизни по объектам социальной инфраструктуры и открытым данным о госзакупках.
      </p>
      <div class="links">
        {archivesByUrl.has("https://minfin.gov.ru/ru/document?id_4=113821-opredeleny_pobediteli_konkursa_minfina_rossii_na_otkrytykh_finansovykh_dannykh_budgetapps") && (
          <a href={`/archive/${archivesByUrl.get("https://minfin.gov.ru/ru/document?id_4=113821-opredeleny_pobediteli_konkursa_minfina_rossii_na_otkrytykh_finansovykh_dannykh_budgetapps")}`}>Минфин (архив)</a>
        )}
        {archivesByUrl.has("https://apptractor.ru/info/interview/anton-lenev-gde-zhit-horosho-o-konkurse-budgetapps.html") && (
          <a href={`/archive/${archivesByUrl.get("https://apptractor.ru/info/interview/anton-lenev-gde-zhit-horosho-o-konkurse-budgetapps.html")}`}>AppTractor (архив)</a>
        )}
        {archivesByUrl.has("https://gazeta-rybinsk.ru/2015/04/29/18147") && (
          <a href={`/archive/${archivesByUrl.get("https://gazeta-rybinsk.ru/2015/04/29/18147")}`}>Газета Рыбинск (архив)</a>
        )}
      </div>
    </article>

    <article class="project">
      <h3>🏅 Social Impact Award Russia 2015 — финалист с EyeLens</h3>
      <p>
        EyeLens, приложение для слабовидящих и людей с нарушениями цветовосприятия, вышло в финал Social Impact Award Russia 2015.
      </p>
      <div class="links">
        <a href="https://www.youtube.com/watch?v=3kBqrkSM83s" target="_blank" rel="noopener">Финалистский ролик</a>
      </div>
    </article>

    <article class="project">
