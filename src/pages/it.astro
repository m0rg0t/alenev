---
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: fill in `uploadDate` (YYYY-MM-DD) for each talk to enable Google video rich results.
const talks = [
  {
    name: 'Странное браузерное API — Дринкап',
    description: 'Доклад Антона Ленева на встрече SPB Frontend Drinkup о малоизвестных и необычных браузерных API.',
    videoId: 'xdY7BrkbRUo',
    url: 'https://www.youtube.com/watch?v=xdY7BrkbRUo&ab_channel=SPBFrontend',
    embedUrl: 'https://www.youtube.com/embed/xdY7BrkbRUo',
    uploadDate: '', // TODO
  },
  {
    name: 'Особенности разработки мобильных приложений для Windows Phone и Windows 8',
    description: 'Доклад Антона Ленева о разработке мобильных приложений для платформ Windows Phone и Windows 8.',
    videoId: 't1tpZejtXGo',
    url: 'https://youtu.be/t1tpZejtXGo',
    embedUrl: 'https://www.youtube.com/embed/t1tpZejtXGo',
    uploadDate: '', // TODO
  },
  {
    name: 'Заменят ли алгоритмы дизайнеров в рекламе?',
    description: 'Доклад Антона Ленева о применении алгоритмов и ИИ в рекламном дизайне.',
    videoId: 'MxjNTSK-UI4',
    url: 'https://www.youtube.com/live/MxjNTSK-UI4',
    embedUrl: 'https://www.youtube.com/embed/MxjNTSK-UI4',
    uploadDate: '', // TODO
  },
];

const videoSchemas = talks.map(t => {
  const schema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    'name': t.name,
    'description': t.description,
    'thumbnailUrl': `https://img.youtube.com/vi/${t.videoId}/hqdefault.jpg`,
    'contentUrl': t.url,
    'embedUrl': t.embedUrl,
    'author': { '@id': 'https://alenev.ru/#person' },
    'inLanguage': 'ru',
  };
  if (t.uploadDate) schema.uploadDate = t.uploadDate;
  return schema;
});
---

<BaseLayout
  title="IT Проекты - Антон Ленев"
  description="IT-проекты, выступления и опыт разработки Антона Ленева — CTO/Frontend Developer, контрибьютор открытого кода. OwlEye, Skull Pin, доклады SPBFrontend."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://alenev.ru/" },
      { "@type": "ListItem", "position": 2, "name": "IT Проекты", "item": "https://alenev.ru/it/" }
    ]
  })} />
  {videoSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
  <h1>💻 IT Проекты и Разработка</h1>

  <section class="section">
    <h2>Pet Проекты</h2>

    <article class="project">
      <h3>OwlEye</h3>
      <p>
        Украшение-ожерелье в виде совы, помогающее слабовидящим людям ориентироваться в закрытых пространствах.
        Во время COVID-19 также помогает соблюдать социальную дистанцию.
      </p>
      <div class="links">
        <a href="https://owleye.space/" target="_blank" rel="noopener">Сайт проекта</a>
        <a href="https://github.com/m0rg0t/OwlEye" target="_blank" rel="noopener">GitHub</a>
      </div>
    </article>

    <article class="project">
      <h3>Skull Pin</h3>
      <p>
        Бренд украшений для волос - заколки, гребни и другие украшения, создаваемые с помощью 3D печати.
      </p>
      <div class="links">
        <a href="https://vk.com/skull_pin" target="_blank" rel="noopener">VK группа</a>
      </div>
    </article>

    <article class="project">
      <h3>Где участковый?</h3>
      <p>Приложение для поиска участковых по адресу.</p>
      <div class="links">
        <a href="https://openpolice.ru/apps/pc-where-is-policeman/" target="_blank" rel="noopener">OpenPolice</a>
      </div>
    </article>

    <article class="project">
      <h3>Rybinsk Secrets</h3>
      <p>Туристический проект для города Рыбинска (в разработке).</p>
    </article>

    <article class="project">
      <h3>Поиск авиабилетов</h3>
      <p>Приложение для Windows Store (устаревший проект).</p>
    </article>
  </section>

  <section class="section">
    <h2>Выступления</h2>

    {talks.map(talk => (
      <article class="talk">
        <h3>{talk.name}</h3>
        <p>{talk.description}</p>
        <div class="links">
          <a href={talk.url} target="_blank" rel="noopener">Смотреть на YouTube</a>
        </div>
      </article>
    ))}
  </section>

  <section class="section">
    <h2>Опыт работы</h2>
    <p>CTO/Frontend Developer в Viewst Inc</p>
    <p>Образование: Рыбинская Государственная Авиационная Технологическая Академия им. П.А. Соловьёва (2006-2011)</p>
    <div class="links">
      <a href="https://github.com/m0rg0t" target="_blank" rel="noopener">GitHub (55 репозиториев)</a>
      <a href="https://www.slideshare.net/antonlenev" target="_blank" rel="noopener">SlideShare</a>
    </div>
  </section>

  <style>
    /* Page Title */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    /* Sections */
    .section {
      margin-bottom: 3rem;
    }

    .section h2 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    /* Project & Talk Cards */
    .project, .talk {
      background: var(--color-surface);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin-bottom: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .project:hover, .talk:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
      border-left-color: var(--color-secondary);
    }

    /* Alternate border colors */
    .project:nth-child(2) { border-left-color: var(--color-accent); }
    .project:nth-child(3) { border-left-color: var(--color-accent-alt); }
    .project:nth-child(4) { border-left-color: var(--color-secondary); }
    .project:nth-child(5) { border-left-color: var(--color-primary); }

    :global([data-theme="dark"]) .project:nth-child(2) { border-left-color: var(--color-accent); }

    .project h3, .talk h3 {
      font-size: 1.3rem;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .project p, .section > p {
      color: var(--color-text-muted);
      line-height: 1.6;
      margin-bottom: 1rem;
      text-transform: none;
    }

    /* Links/Buttons */
    .links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .links a {
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
    }

    .links a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--color-border);
      background: var(--color-primary-dark);
    }

    /* Responsive */
    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
        padding: 0.5rem 1rem;
      }

      .project, .talk {
        box-shadow: 3px 3px 0 var(--color-border);
      }

      .links a {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }
    }
  </style>
</BaseLayout>
