    .archive-link {
      background: var(--color-accent-alt) !important;
      color: #1a1a1a !important;
    }

    .archive-link:hover {
      background: #5ab868 !important;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      .publication, .mention, .achievement {
        box-shadow: 3px 3px 0 var(--color-border);
      }

      .publication .links a, .mention .links a, .achievement .links a {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }
    }
