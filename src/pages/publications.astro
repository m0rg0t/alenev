---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all archives to check which publications have archived versions
const archives = await getCollection('archives');
const archivesByUrl = new Map(archives.map(a => [a.data.originalUrl, a.slug]));
---

<BaseLayout title="Публикации - Антон Ленев">
