    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://alenev.ru/" },
      { "@type": "ListItem", "position": 2, "name": "Publications", "item": "https://alenev.ru/publications/" }
    ]
  })} />
  <h1>📝 Публикации и Статьи</h1>

  <section class="section">
    <h2>Мои статьи</h2>

    <article class="publication">
      <h3>OwlEye Necklace - Jewelry That Helps Visually Impaired People Navigate</h3>
