  <style>
    /* Page Title */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: var(--color-text);
      text-transform: uppercase;
      display: inline-block;
      background: var(--color-accent);
      padding: 0.75rem 1.5rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    :global([data-theme="dark"]) h1 {
      color: #1a1a1a;
    }

    .section {
      margin-bottom: 4rem;
    }

    .section h2 {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      display: inline-block;
      background: var(--color-primary);
      color: white;
      padding: 0.5rem 1rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: 3px 3px 0 var(--color-border);
      text-transform: uppercase;
    }

    .publication, .mention, .achievement {
      background: var(--color-surface);
      padding: 1.5rem 1.5rem 1.5rem 2rem;
      margin-bottom: 1.5rem;
      border: var(--border-width) solid var(--color-border);
      border-left: 8px solid var(--color-primary);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
    }

    .publication:hover, .mention:hover, .achievement:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--color-border);
      border-left-color: var(--color-secondary);
    }

    .publication:nth-child(2) { border-left-color: var(--color-accent); }
    .publication:nth-child(3) { border-left-color: var(--color-accent-alt); }
    .publication:nth-child(4) { border-left-color: var(--color-secondary); }

    .mention:nth-child(2) { border-left-color: var(--color-accent); }
    .mention:nth-child(3) { border-left-color: var(--color-accent-alt); }
    .mention:nth-child(4) { border-left-color: var(--color-secondary); }
    .mention:nth-child(5) { border-left-color: var(--color-primary); }
    .mention:nth-child(6) { border-left-color: var(--color-accent); }
    .mention:nth-child(7) { border-left-color: var(--color-accent-alt); }
    .mention:nth-child(8) { border-left-color: var(--color-secondary); }
    .mention:nth-child(9) { border-left-color: var(--color-primary); }
    .mention:nth-child(10) { border-left-color: var(--color-accent); }
    .mention:nth-child(11) { border-left-color: var(--color-accent-alt); }
    .mention:nth-child(12) { border-left-color: var(--color-secondary); }
    .mention:nth-child(13) { border-left-color: var(--color-primary); }
    .mention:nth-child(14) { border-left-color: var(--color-accent); }

    .publication:nth-child(5) { border-left-color: var(--color-primary); }
    .publication:nth-child(6) { border-left-color: var(--color-accent); }

    :global([data-theme="dark"]) .publication:nth-child(2),
    :global([data-theme="dark"]) .publication:nth-child(6),
    :global([data-theme="dark"]) .mention:nth-child(2),
    :global([data-theme="dark"]) .mention:nth-child(6),
    :global([data-theme="dark"]) .mention:nth-child(10),
    :global([data-theme="dark"]) .mention:nth-child(14) {
      border-left-color: var(--color-accent);
    }

    .publication h3, .mention h3, .achievement h3 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
      color: var(--color-text);
      text-transform: uppercase;
    }

    .publication p {
      color: var(--color-text-muted);
      margin-bottom: 1rem;
      line-height: 1.6;
      text-transform: none;
    }

    .links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 0.5rem;
    }

    .publication .links a, .mention .links a, .achievement .links a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--color-primary);
      color: white;
      text-decoration: none;
      border: var(--border-width) solid var(--color-border);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      box-shadow: 2px 2px 0 var(--color-border);
      margin-top: 0;
